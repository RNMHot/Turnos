@page "/events"
@attribute [Authorize(Policy = "AppAccess", Roles = "Gerencia,Admin")]
@rendermode InteractiveServer
@inject EventService EventSvc
@inject CompanyService CompanySvc
@inject ExcelExportService Excel
@inject AuthenticationStateProvider AuthState
@inject IJSRuntime JS
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject AppSettingsState SettingsState

<PageTitle>Eventos — Turnos</PageTitle>

<style>
    .tbl-compact td, .tbl-compact th { padding: 7px 8px !important; }
    .tbl-compact .mud-table-sort-label { font-size: inherit; }
</style>

<div class="d-flex justify-content-between align-items-center mb-3">
    <MudText Typo="Typo.h5">Eventos</MudText>
    <div class="d-flex gap-2">
        <MudButton Variant="Variant.Outlined" Color="Color.Success"
                   StartIcon="@Icons.Material.Filled.FileDownload"
                   OnClick="ExportExcel" Size="Size.Small">Exportar</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   Href="/events/new" Size="Size.Small">Agregar Evento</MudButton>
    </div>
</div>

<div class="d-flex gap-2 mb-3 flex-wrap align-items-center">
    <MudTextField T="string" Value="@search" ValueChanged="OnSearchChanged"
                  Placeholder="Búsqueda…" Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  Immediate="true" Clearable="true"
                  Style="max-width:260px" Variant="Variant.Outlined" Margin="Margin.Dense" />

    <MudSelect T="int?" Value="@filterCompanyId" ValueChanged="OnCompanyChanged"
               Placeholder="Clientes" Style="max-width:310px"
               Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
        @foreach (var c in companies)
        {
            <MudSelectItem T="int?" Value="@((int?)c.CompanyId)">@c.Name</MudSelectItem>
        }
    </MudSelect>

    <MudDatePicker Date="@filterFrom" DateChanged="OnFromChanged"
                   Placeholder="Desde" Style="max-width:180px"
                   Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" />

    <MudDatePicker Date="@filterTo" DateChanged="OnToChanged"
                   Placeholder="Hasta" Style="max-width:180px"
                   Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" />

    <MudSelect T="string" Value="@filterActive" ValueChanged="OnActiveChanged"
               Placeholder="Estatus" Style="max-width:160px"
               Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
        <MudSelectItem T="string" Value="@("true")">Activos</MudSelectItem>
        <MudSelectItem T="string" Value="@("false")">Inactivos</MudSelectItem>
    </MudSelect>
</div>

<MudTable Items="@events" Dense="true" Hover="true"
          T="Event" Elevation="2" Class="rounded tbl-compact" Style="font-size:0.8rem"
          RowStyleFunc="@((item, _) => !item.Active ? "background-color:#e9ecef; color:#6c757d;" : null)">
    <HeaderContent>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<Event, object>(x => x.EventName)">Evento</MudTableSortLabel>
        </MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<Event, object>(x => x.Company?.Name ?? string.Empty)">Cliente</MudTableSortLabel>
        </MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<Event, object>(x => x.StartDateTime)">Inicio</MudTableSortLabel>
        </MudTh>
        <MudTh>Fin</MudTh>
        <MudTh>Personal</MudTh>
        <MudTh>Localización</MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<Event, object>(x => x.Active)">Estatus</MudTableSortLabel>
        </MudTh>
        <MudTh></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Evento">@context.EventName</MudTd>
        <MudTd DataLabel="Cliente">@context.Company?.Name</MudTd>
        <MudTd DataLabel="Inicio">@SettingsState.ToDisplay(context.StartDateTime).ToString("MMM d, h:mm tt")</MudTd>
        <MudTd DataLabel="Fin">@SettingsState.ToDisplay(context.EndDateTime).ToString("h:mm tt")</MudTd>
        <MudTd DataLabel="Personal">@FormatRequirements(context)</MudTd>
        <MudTd DataLabel="Localización">@(context.Location?.Name ?? "—")</MudTd>
        <MudTd DataLabel="Estatus">
            <MudChip T="string" Color="@(context.Active ? Color.Success : Color.Default)"
                     Size="Size.Small" Variant="Variant.Filled" Class="ma-0">
                @(context.Active ? "Activo" : "Inactivo")
            </MudChip>
        </MudTd>
        <MudTd DataLabel="">
            <div style="display:flex; align-items:center; justify-content:flex-end">
                <MudTooltip Text="Editar">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary"
                                   Size="Size.Small" Href="@($"/events/{context.EventId}")" />
                </MudTooltip>
                <MudTooltip Text="Eliminar">
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                   Size="Size.Small" OnClick="() => ConfirmDelete(context)" />
                </MudTooltip>
            </div>
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText Typo="Typo.body1" Class="py-4 mud-text-secondary" Style="display:block;text-align:center">
            No se encontraron eventos.
        </MudText>
    </NoRecordsContent>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[] { 25, 50, 100 }" />
    </PagerContent>
</MudTable>

@code {
    private List<Event> events = new();
    private List<Company> companies = new();
    private string search = "";
    private int? filterCompanyId;
    private DateTime? filterFrom;
    private DateTime? filterTo;
    private string filterActive = "";
    private string userId = "";

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
        companies = await CompanySvc.GetAllAsync();
        await Load();
    }

    private async Task Load()
    {
        bool? active = filterActive == "true" ? true : filterActive == "false" ? false : null;
        events = await EventSvc.GetAllAsync(search, filterCompanyId, filterFrom, filterTo, active);
    }

    private async Task OnSearchChanged(string val) { search = val; await Load(); }
    private async Task OnCompanyChanged(int? val) { filterCompanyId = val; await Load(); }
    private async Task OnFromChanged(DateTime? val) { filterFrom = val; await Load(); }
    private async Task OnToChanged(DateTime? val) { filterTo = val; await Load(); }
    private async Task OnActiveChanged(string val) { filterActive = val ?? ""; await Load(); }

    private async Task ConfirmDelete(Event e)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Eliminar Evento",
            $"¿Deseas eliminar el evento {e.EventName}?",
            yesText: "Sí, eliminar",
            cancelText: "No");

        if (confirmed == true)
        {
            await EventSvc.DeactivateAsync(e.EventId, userId);
            Snackbar.Add("Evento eliminado", Severity.Info);
            await Load();
        }
    }

    private async Task ExportExcel()
    {
        var bytes = Excel.ExportEvents(events);
        await JS.InvokeVoidAsync("downloadFile", "events.xlsx", Convert.ToBase64String(bytes));
    }

    private static string FormatRequirements(Event ev)
    {
        var otherLabel = string.IsNullOrWhiteSpace(ev.RequiredOtherLabel) ? "Otro" : ev.RequiredOtherLabel;
        return $"Sup: {ev.RequiredSupervisors}, Ushers: {ev.RequiredUshers}, {otherLabel}: {ev.RequiredOther}";
    }
}
