<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Asignar a @EventName</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField T="string" Value="@_search" ValueChanged="OnSearchChanged"
                      Placeholder="Búsqueda…" Immediate="true" Clearable="true"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2" />

        <div style="max-height:300px;overflow-y:auto">
            @if (_filtered.Count == 0)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="px-1">Sin resultados</MudText>
            }
            else
            {
                @foreach (var person in _filtered)
                {
                    var assigned = _assignedIds.Contains(person.PersonId);
                    <MudChip T="string" OnClick="@(() => Pick(person))"
                             Variant="@(assigned ? Variant.Outlined : Variant.Filled)"
                             Icon="@(assigned ? Icons.Material.Filled.Check : Icons.Material.Filled.Person)"
                             Class="mb-1" Style="@($"{GetRoleStyle(person)}cursor:pointer;width:100%;justify-content:flex-start;{(assigned ? "opacity:0.6" : "")}")">
                        @person.FullName
                    </MudChip>
                }
            }
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close" Variant="Variant.Text">Cerrar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public string EventName { get; set; } = "";
    [Parameter] public List<Person> Personnel { get; set; } = new();
    [Parameter] public Func<Person, Task<bool>>? OnPick { get; set; }

    private string _search = "";
    private List<Person> _filtered = new();
    private readonly HashSet<int> _assignedIds = new();

    protected override void OnInitialized() => _filtered = Personnel.ToList();

    private void OnSearchChanged(string val)
    {
        _search = val;
        _filtered = string.IsNullOrWhiteSpace(val)
            ? Personnel.ToList()
            : Personnel.Where(p => p.FullName.Contains(val, StringComparison.OrdinalIgnoreCase)).ToList();
    }

    private async Task Pick(Person person)
    {
        if (_assignedIds.Contains(person.PersonId) || OnPick is null) return;

        if (await OnPick(person))
            _assignedIds.Add(person.PersonId);
    }

    private void Close() => MudDialog.Close();

    private static string GetRoleStyle(Person p)
    {
        var roles = p.PersonRoles.Select(r => r.Role?.Name).ToList();
        bool isUsher = roles.Contains("Ujier");
        bool isSup = roles.Contains("Supervisor");
        return (isUsher, isSup) switch
        {
            (true, true) => "background:#EDF0F4;border:1px solid #5B6F86;color:#2A3A4A;",
            (false, true) => "background:#FAF0E3;border:1px solid #C97832;color:#7A4A1E;",
            _ => "background:#E0F0F1;border:1px solid #2D8C91;color:#1A5558;"
        };
    }
}
