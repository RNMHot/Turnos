@page "/events/new"
@page "/events/{Id:int}"
@attribute [Authorize(Policy = "AppAccess", Roles = "Gerencia,Admin")]
@rendermode InteractiveServer
@inject EventService EventSvc
@inject CompanyService CompanySvc
@inject LocationService LocationSvc
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav
@inject IJSRuntime JS
@using System.Globalization

<PageTitle>@(Id == 0 ? "Nuevo Evento" : "Editar Evento") — Turnos</PageTitle>

<div class="d-flex align-items-center gap-2 mb-3">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Variant="Variant.Outlined"
                   Size="Size.Small" OnClick="GoBack" title="Regresar" />
    <MudText Typo="Typo.h5">@(Id == 0 ? "Nuevo Evento" : "Editar Evento")</MudText>
</div>

<MudPaper Elevation="2" Class="pa-4 rounded" Style="max-width:700px">
    <EditForm Model="ev" OnValidSubmit="Save">
        <DataAnnotationsValidator />

        <MudGrid Spacing="3">
            <MudItem xs="12">
                <MudTextField @bind-Value="ev.EventName" For="() => ev.EventName"
                              Label="Nombre de evento *"
                              Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect T="int" @bind-Value="ev.CompanyId" For="() => ev.CompanyId"
                           Label="Cliente *" Variant="Variant.Outlined" Margin="Margin.Dense">
                    <MudSelectItem T="int" Value="0">— Seleccionar cliente —</MudSelectItem>
                    @foreach (var c in companies)
                    {
                        <MudSelectItem T="int" Value="@c.CompanyId">@c.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect T="int?" @bind-Value="ev.LocationId" Label="Localización"
                           Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                    @foreach (var l in locations)
                    {
                        <MudSelectItem T="int?" Value="@((int?)l.LocationId)">@l.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            @if (!createMultiple)
            {
                <MudItem xs="12" sm="6" md="3">
                    <MudDatePicker Date="@_startDate" DateChanged="OnStartDateChanged"
                                   Label="Fecha inicio" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudTimePicker Time="@_startTime" TimeChanged="OnStartTimeChanged"
                                   Label="Hora inicio" Variant="Variant.Outlined" Margin="Margin.Dense"
                                   AmPm="true" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudDatePicker Date="@_endDate" DateChanged="OnEndDateChanged"
                                   Label="Fecha fin" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudTimePicker Time="@_endTime" TimeChanged="OnEndTimeChanged"
                                   Label="Hora fin" Variant="Variant.Outlined" Margin="Margin.Dense"
                                   AmPm="true" />
                </MudItem>
            }

            <MudItem xs="12" sm="4">
                <MudNumericField T="int" @bind-Value="ev.RequiredSupervisors"
                                 For="() => ev.RequiredSupervisors"
                                 Label="Supervisores" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudNumericField T="int" @bind-Value="ev.RequiredUshers"
                                 For="() => ev.RequiredUshers"
                                 Label="Ushers" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" />
            </MudItem>
            <MudItem xs="12" sm="4">
                @if (editingOtherLabel)
                {
                    <MudTextField @bind-Value="ev.RequiredOtherLabel"
                                  AutoFocus="true"
                                  OnBlur="@(_ => StopEditingOtherLabel())"
                                  OnKeyDown="OnOtherLabelKeyDown"
                                  Label="Etiqueta"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                }
                else
                {
                    <div @ondblclick="StartEditingOtherLabel" title="Doble clic para editar la etiqueta">
                        <MudNumericField T="int" @bind-Value="ev.RequiredOther"
                                         For="() => ev.RequiredOther"
                                         Label="@OtherLabelText"
                                         Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" />
                    </div>
                }
            </MudItem>

            @if (Id == 0)
            {
                <MudItem xs="12">
                    <MudCheckBox T="bool" @bind-Value="createMultiple"
                                 Label="Crear varias ocurrencias" />
                </MudItem>
            }

            @if (createMultiple && Id == 0)
            {
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                        Puedes agregar una o más reglas. Cada regla puede usar un horario diferente.
                        Se crearán <strong>@PreviewCount evento(s)</strong> en total.
                    </MudAlert>
                    @if (recurrenceError is not null)
                    {
                        <MudAlert Severity="Severity.Error" Dense="true">@recurrenceError</MudAlert>
                    }
                </MudItem>

                <MudItem xs="12">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <MudText Typo="Typo.subtitle2">Reglas de recurrencia</MudText>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Add" Size="Size.Small"
                                   OnClick="AddRecurrenceRule">Agregar regla</MudButton>
                    </div>

                    @for (var i = 0; i < recurrenceRules.Count; i++)
                    {
                        var rule = recurrenceRules[i];
                        var ruleIndex = i;
                        <MudPaper Outlined="true" Class="pa-3 mb-3" @key="rule">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <MudText Typo="Typo.subtitle2">Regla @(ruleIndex + 1)</MudText>
                                @if (recurrenceRules.Count > 1)
                                {
                                    <MudButton Variant="Variant.Outlined" Color="Color.Error"
                                               Size="Size.Small"
                                               OnClick="@(() => RemoveRecurrenceRule(rule))">Quitar</MudButton>
                                }
                            </div>

                            <MudGrid Spacing="2">
                                <MudItem xs="12" sm="4">
                                    <MudSelect T="RecurrenceRuleKind" @bind-Value="rule.Kind"
                                               Label="Tipo" Variant="Variant.Outlined" Margin="Margin.Dense">
                                        <MudSelectItem Value="RecurrenceRuleKind.SingleDate">Un día</MudSelectItem>
                                        <MudSelectItem Value="RecurrenceRuleKind.WeekdaysInRange">Días de la semana en rango</MudSelectItem>
                                        <MudSelectItem Value="RecurrenceRuleKind.SpecificDates">Fechas específicas</MudSelectItem>
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" sm="4">
                                    <MudTimePicker Time="@ParseRuleTime(rule.StartTimeText)"
                                                   TimeChanged="@(t => rule.StartTimeText = FormatRuleTime(t, rule.StartTimeText))"
                                                   Label="Hora inicio" Variant="Variant.Outlined" Margin="Margin.Dense"
                                                   AmPm="true" />
                                </MudItem>
                                <MudItem xs="12" sm="4">
                                    <MudTimePicker Time="@ParseRuleTime(rule.EndTimeText)"
                                                   TimeChanged="@(t => rule.EndTimeText = FormatRuleTime(t, rule.EndTimeText))"
                                                   Label="Hora fin" Variant="Variant.Outlined" Margin="Margin.Dense"
                                                   AmPm="true" />
                                </MudItem>

                                @if (rule.Kind == RecurrenceRuleKind.SingleDate)
                                {
                                    <MudItem xs="12" sm="6">
                                        <MudDatePicker Date="@((DateTime?)rule.SingleDate)"
                                                       DateChanged="@(d => { if (d.HasValue) rule.SingleDate = d.Value.Date; })"
                                                       Label="Fecha" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                    </MudItem>
                                }
                                else if (rule.Kind == RecurrenceRuleKind.WeekdaysInRange)
                                {
                                    <MudItem xs="12" sm="6">
                                        <MudDatePicker Date="@((DateTime?)rule.RangeStartDate)"
                                                       DateChanged="@(d => { if (d.HasValue) rule.RangeStartDate = d.Value.Date; })"
                                                       Label="Desde" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                    </MudItem>
                                    <MudItem xs="12" sm="6">
                                        <MudDatePicker Date="@((DateTime?)rule.RangeEndDate)"
                                                       DateChanged="@(d => { if (d.HasValue) rule.RangeEndDate = d.Value.Date; })"
                                                       Label="Hasta" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                    </MudItem>
                                    <MudItem xs="12">
                                        <MudText Typo="Typo.body2" Class="mb-1">Días de la semana</MudText>
                                        <div class="d-flex flex-wrap gap-2">
                                            @foreach (var day in DaysOrdered)
                                            {
                                                <MudCheckBox T="bool" Value="@rule.Days.Contains(day)"
                                                             ValueChanged="@(v => ToggleRuleDay(rule, day, v))"
                                                             Label="@DayName(day)" Dense="true" />
                                            }
                                        </div>
                                    </MudItem>
                                }
                                else if (rule.Kind == RecurrenceRuleKind.SpecificDates)
                                {
                                    <MudItem xs="12">
                                        <MudTextField T="string" Value="@rule.SpecificDatesText"
                                                      ValueChanged="@(v => rule.SpecificDatesText = v ?? string.Empty)"
                                                      Lines="3" Label="Fechas"
                                                      Placeholder="Una fecha por línea o separadas por coma: 2026-07-03, 2026-07-04"
                                                      HelperText="Formato: AAAA-MM-DD. Una por línea o separadas por coma."
                                                      Variant="Variant.Outlined" />
                                    </MudItem>
                                }
                            </MudGrid>
                        </MudPaper>
                    }
                </MudItem>
            }

            <MudItem xs="12">
                <MudTextField @bind-Value="ev.Notes" Label="Notas"
                              Lines="3" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12">
                <MudCheckBox T="bool" @bind-Value="ev.Active" Label="Activo" />
            </MudItem>
        </MudGrid>

        @if (saveError is not null)
        {
            <MudAlert Severity="Severity.Error" Class="mt-3">@saveError</MudAlert>
        }

        <div class="d-flex gap-2 mt-4">
            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled"
                       Color="Color.Primary" Disabled="@saving">
                @(saving ? "Guardando…" : "Guardar")
            </MudButton>
            <MudButton Variant="Variant.Outlined" OnClick="GoBack">Cancelar</MudButton>
        </div>
    </EditForm>
</MudPaper>

@code {
    [Parameter] public int Id { get; set; }

    [SupplyParameterFromQuery(Name = "start")]
    public string? StartParam { get; set; }

    private async Task GoBack() => await JS.InvokeVoidAsync("history.back");

    private void StartEditingOtherLabel() => editingOtherLabel = true;

    private void StopEditingOtherLabel()
    {
        if (string.IsNullOrWhiteSpace(ev.RequiredOtherLabel))
            ev.RequiredOtherLabel = "Otros";
        editingOtherLabel = false;
    }

    private void OnOtherLabelKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" || e.Key == "Escape")
            StopEditingOtherLabel();
    }

    private Event ev = new()
    {
        Active = true,
        StartDateTime = RoundDownToHourUtc(DateTime.UtcNow),
        EndDateTime = RoundDownToHourUtc(DateTime.UtcNow).AddHours(4),
        RequiredOtherLabel = "Otros"
    };

    private List<Company> companies = new();
    private List<Location> locations = new();
    private bool saving;
    private bool editingOtherLabel;
    private string OtherLabelText => string.IsNullOrWhiteSpace(ev.RequiredOtherLabel) ? "Otros" : ev.RequiredOtherLabel;
    private bool createMultiple;
    private string? recurrenceError;
    private string? saveError;
    private string userId = string.Empty;
    private DateTime startLocal;
    private DateTime endLocal;
    private DateTime? _startDate;
    private TimeSpan? _startTime;
    private DateTime? _endDate;
    private TimeSpan? _endTime;
    private readonly List<RecurrenceRuleEditor> recurrenceRules = new();

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? string.Empty;
        companies = await CompanySvc.GetAllAsync();
        locations = await LocationSvc.GetAllAsync();

        if (Id != 0)
        {
            var existing = await EventSvc.GetByIdAsync(Id);
            if (existing is not null)
                ev = existing;
        }

        if (string.IsNullOrWhiteSpace(ev.RequiredOtherLabel))
            ev.RequiredOtherLabel = "Otros";

        if (Id == 0 && recurrenceRules.Count == 0)
            recurrenceRules.Add(CreateDefaultRule());

        startLocal = ToLocalInputTime(ev.StartDateTime);
        endLocal = ToLocalInputTime(ev.EndDateTime);

        if (Id == 0 && !string.IsNullOrEmpty(StartParam) &&
            DateTime.TryParse(StartParam, out var parsedStart))
        {
            startLocal = parsedStart;
            endLocal = parsedStart.AddHours(4);
            OnStartChanged();
        }

        _startDate = startLocal.Date;
        _startTime = startLocal.TimeOfDay;
        _endDate = endLocal.Date;
        _endTime = endLocal.TimeOfDay;
    }

    private void OnStartDateChanged(DateTime? date)
    {
        _startDate = date;
        startLocal = (date?.Date ?? DateTime.Today) + (_startTime ?? TimeSpan.Zero);
        OnStartChanged();
        _endDate = endLocal.Date;
        _endTime = endLocal.TimeOfDay;
    }

    private void OnStartTimeChanged(TimeSpan? time)
    {
        _startTime = time;
        startLocal = (_startDate?.Date ?? DateTime.Today) + (time ?? TimeSpan.Zero);
        OnStartChanged();
        _endDate = endLocal.Date;
        _endTime = endLocal.TimeOfDay;
    }

    private void OnEndDateChanged(DateTime? date)
    {
        _endDate = date;
        endLocal = (date?.Date ?? DateTime.Today) + (_endTime ?? TimeSpan.Zero);
    }

    private void OnEndTimeChanged(TimeSpan? time)
    {
        _endTime = time;
        endLocal = (_endDate?.Date ?? DateTime.Today) + (time ?? TimeSpan.Zero);
    }

    private async Task Save()
    {
        saving = true;
        saveError = null;
        try
        {
            if (Id == 0 && createMultiple)
            {
                var occurrences = BuildOccurrences();
                if (!occurrences.Any())
                {
                    recurrenceError = "No se generaron ocurrencias. Verifica que las reglas tengan fechas válidas y, para días de la semana, que hayas seleccionado al menos un día.";
                    return;
                }
                recurrenceError = null;

                foreach (var occurrence in occurrences)
                {
                    await EventSvc.CreateAsync(occurrence, userId);
                }
            }
            else
            {
                ev.StartDateTime = DateTime.SpecifyKind(startLocal, DateTimeKind.Local).ToUniversalTime();
                ev.EndDateTime = DateTime.SpecifyKind(endLocal, DateTimeKind.Local).ToUniversalTime();

                if (Id == 0)
                    await EventSvc.CreateAsync(ev, userId);
                else
                    await EventSvc.UpdateAsync(ev, userId);
            }

            Nav.NavigateTo("/events");
        }
        catch (Exception ex)
        {
            saveError = ex.InnerException?.Message ?? ex.Message;
        }
        finally
        {
            saving = false;
        }
    }

    private static DateTime ToLocalInputTime(DateTime value)
    {
        return value.Kind switch
        {
            DateTimeKind.Utc => value.ToLocalTime(),
            DateTimeKind.Local => value,
            _ => DateTime.SpecifyKind(value, DateTimeKind.Local)
        };
    }

    private void OnStartChanged()
    {
        if (Id != 0)
            return;

        endLocal = startLocal.AddHours(4);

        if (!createMultiple && recurrenceRules.Count > 0)
        {
            recurrenceRules[0].StartTimeText = startLocal.ToString("HH:mm");
            recurrenceRules[0].EndTimeText = endLocal.ToString("HH:mm");
            recurrenceRules[0].SingleDate = startLocal.Date;
        }
    }

    private void AddRecurrenceRule() => recurrenceRules.Add(CreateDefaultRule());

    private void RemoveRecurrenceRule(RecurrenceRuleEditor rule)
    {
        if (recurrenceRules.Count > 1)
            recurrenceRules.Remove(rule);
    }

    private void ToggleRuleDay(RecurrenceRuleEditor rule, DayOfWeek day, bool selected)
    {
        if (selected)
        {
            if (!rule.Days.Contains(day))
                rule.Days.Add(day);
        }
        else
        {
            rule.Days.Remove(day);
        }
    }

    private List<Event> BuildOccurrences()
    {
        var occurrences = new List<Event>();
        foreach (var rule in recurrenceRules)
        {
            foreach (var occurrence in BuildOccurrences(rule))
                occurrences.Add(occurrence);
        }

        return occurrences;
    }

    private IEnumerable<Event> BuildOccurrences(RecurrenceRuleEditor rule)
    {
        var dates = rule.Kind switch
        {
            RecurrenceRuleKind.SingleDate => new[] { rule.SingleDate.Date },
            RecurrenceRuleKind.WeekdaysInRange => BuildWeekdayDates(rule),
            RecurrenceRuleKind.SpecificDates => ParseSpecificDates(rule.SpecificDatesText),
            _ => Enumerable.Empty<DateTime>()
        };

        if (!TryParseTime(rule.StartTimeText, out var startTime) || !TryParseTime(rule.EndTimeText, out var endTime))
            yield break;

        foreach (var date in dates.Distinct().OrderBy(d => d))
        {
            var start = date.Date.Add(startTime);
            var end = date.Date.Add(endTime);
            if (end <= start)
                end = end.AddDays(1);

            yield return new Event
            {
                CompanyId = ev.CompanyId,
                EventName = ev.EventName,
                StartDateTime = DateTime.SpecifyKind(start, DateTimeKind.Local).ToUniversalTime(),
                EndDateTime = DateTime.SpecifyKind(end, DateTimeKind.Local).ToUniversalTime(),
                RequiredSupervisors = ev.RequiredSupervisors,
                RequiredUshers = ev.RequiredUshers,
                RequiredOther = ev.RequiredOther,
                RequiredOtherLabel = ev.RequiredOtherLabel,
                LocationId = ev.LocationId,
                Notes = ev.Notes,
                Active = ev.Active,
            };
        }
    }

    private IEnumerable<DateTime> BuildWeekdayDates(RecurrenceRuleEditor rule)
    {
        var from = rule.RangeStartDate.Date;
        var to = rule.RangeEndDate.Date;

        if (to < from)
            (from, to) = (to, from);

        for (var date = from; date <= to; date = date.AddDays(1))
        {
            if (rule.Days.Contains(date.DayOfWeek))
                yield return date;
        }
    }

    private static IEnumerable<DateTime> ParseSpecificDates(string? text)
    {
        if (string.IsNullOrWhiteSpace(text))
            yield break;

        var parts = text.Split(new[] { ',', '\n', '\r', ';' }, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        foreach (var part in parts)
        {
            if (DateTime.TryParse(part, CultureInfo.InvariantCulture, DateTimeStyles.None, out var parsed))
                yield return parsed.Date;
            else if (DateTime.TryParse(part, CultureInfo.CurrentCulture, DateTimeStyles.None, out parsed))
                yield return parsed.Date;
        }
    }

    private static bool TryParseTime(string? text, out TimeSpan time)
    {
        if (TimeSpan.TryParse(text, out time))
            return true;

        time = default;
        return false;
    }

    private static TimeSpan? ParseRuleTime(string text) =>
        TimeSpan.TryParse(text, out var t) ? t : null;

    private static string FormatRuleTime(TimeSpan? time, string fallback) =>
        time?.ToString(@"hh\:mm") ?? fallback;

    private static RecurrenceRuleEditor CreateDefaultRule() => new()
    {
        Kind = RecurrenceRuleKind.SingleDate,
        SingleDate = DateTime.Today,
        RangeStartDate = DateTime.Today,
        RangeEndDate = DateTime.Today.AddDays(30),
        StartTimeText = "09:00",
        EndTimeText = "17:00"
    };

    private static readonly DayOfWeek[] DaysOrdered =
    [
        DayOfWeek.Monday, DayOfWeek.Tuesday, DayOfWeek.Wednesday,
        DayOfWeek.Thursday, DayOfWeek.Friday, DayOfWeek.Saturday, DayOfWeek.Sunday
    ];

    private static string DayName(DayOfWeek day) => day switch
    {
        DayOfWeek.Monday    => "Lun",
        DayOfWeek.Tuesday   => "Mar",
        DayOfWeek.Wednesday => "Mié",
        DayOfWeek.Thursday  => "Jue",
        DayOfWeek.Friday    => "Vie",
        DayOfWeek.Saturday  => "Sáb",
        DayOfWeek.Sunday    => "Dom",
        _ => day.ToString()
    };

    private int PreviewCount => createMultiple ? BuildOccurrences().Count : 0;

    private static DateTime RoundDownToHourUtc(DateTime value)
    {
        var utcValue = value.Kind switch
        {
            DateTimeKind.Utc => value,
            DateTimeKind.Local => value.ToUniversalTime(),
            _ => DateTime.SpecifyKind(value, DateTimeKind.Utc)
        };

        return new DateTime(utcValue.Year, utcValue.Month, utcValue.Day, utcValue.Hour, 0, 0, DateTimeKind.Utc);
    }

    private enum RecurrenceRuleKind
    {
        SingleDate,
        WeekdaysInRange,
        SpecificDates
    }

    private sealed class RecurrenceRuleEditor
    {
        public RecurrenceRuleKind Kind { get; set; }
        public DateTime SingleDate { get; set; }
        public DateTime RangeStartDate { get; set; }
        public DateTime RangeEndDate { get; set; }
        public string StartTimeText { get; set; } = "09:00";
        public string EndTimeText { get; set; } = "17:00";
        public string SpecificDatesText { get; set; } = string.Empty;
        public List<DayOfWeek> Days { get; } = new();
    }
}
