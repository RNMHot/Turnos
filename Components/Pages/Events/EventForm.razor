@page "/events/new"
@page "/events/{Id:int}"
@attribute [Authorize]
@rendermode InteractiveServer
@inject EventService EventSvc
@inject CompanyService CompanySvc
@inject LocationService LocationSvc
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

<PageTitle>@(Id == 0 ? "Nuevo Evento" : "Editar Evento") — Turnos</PageTitle>

<div class="d-flex align-items-center gap-2 mb-3">
    <a href="/events" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h4 class="mb-0">@(Id == 0 ? "Nuevo Evento" : "Editar Evento")</h4>
</div>

<div class="card shadow-sm" style="max-width:700px">
    <div class="card-body">
        <EditForm Model="ev" OnValidSubmit="Save">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" />

            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label">Nombre de evento *</label>
                    <InputText @bind-Value="ev.EventName" class="form-control" />
                    <ValidationMessage For="() => ev.EventName" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Cliente *</label>
                    <InputSelect @bind-Value="ev.CompanyId" class="form-select">
                        <option value="0">— Seleccionar cliente —</option>
                        @foreach (var c in companies)
                        {
                            <option value="@c.CompanyId">@c.Name</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Localización</label>
                    <InputSelect @bind-Value="ev.LocationId" class="form-select">
                        <option value="">— Sin localización —</option>
                        @foreach (var l in locations)
                        {
                            <option value="@l.LocationId">@l.Name</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-md-6 @(ev.IsRecurring ? "d-none" : "")">
                    <label class="form-label">Inicio</label>
                    <input type="datetime-local" class="form-control" @bind="startLocal" @bind:after="OnStartChanged" />
                </div>
                <div class="col-md-6 @(ev.IsRecurring ? "d-none" : "")">
                    <label class="form-label">Fin</label>
                    <input type="datetime-local" class="form-control" @bind="endLocal" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Supervisores</label>
                    <InputNumber @bind-Value="ev.RequiredSupervisors" class="form-control" />
                    <ValidationMessage For="() => ev.RequiredSupervisors" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Ushers</label>
                    <InputNumber @bind-Value="ev.RequiredUshers" class="form-control" />
                    <ValidationMessage For="() => ev.RequiredUshers" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Otros</label>
                    <InputNumber @bind-Value="ev.RequiredOther" class="form-control" />
                    <ValidationMessage For="() => ev.RequiredOther" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Etiqueta de otros</label>
                    <InputText @bind-Value="ev.RequiredOtherLabel" class="form-control" />
                    <ValidationMessage For="() => ev.RequiredOtherLabel" />
                </div>
                <div class="col-12">
                    <div class="form-check">
                        <InputCheckbox @bind-Value="ev.IsRecurring" class="form-check-input" id="recurring" />
                        <label class="form-check-label" for="recurring">Crear varias ocurrencias</label>
                    </div>
                </div>
                @if (ev.IsRecurring)
                {
                    <div class="col-12">
                        <div class="alert alert-info py-2 mb-2">
                            Agrega una o más reglas. Cada regla puede usar un horario diferente.
                            Se crearán <strong>@PreviewCount evento(s)</strong> en total.
                        </div>
                        @if (recurrenceError is not null)
                        {
                            <div class="alert alert-danger py-2">@recurrenceError</div>
                        }
                    </div>

                    <div class="col-12">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <label class="form-label mb-0">Reglas de recurrencia</label>
                            <button type="button" class="btn btn-sm btn-outline-primary" @onclick="AddRecurrenceRule">
                                <i class="bi bi-plus me-1"></i>Agregar regla
                            </button>
                        </div>

                        @for (var i = 0; i < recurrenceRules.Count; i++)
                        {
                            var rule = recurrenceRules[i];
                            <div class="border rounded p-3 mb-3 bg-light" @key="rule">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <strong>Regla @(i + 1)</strong>
                                    @if (recurrenceRules.Count > 1)
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-danger" @onclick="@(() => RemoveRecurrenceRule(rule))">Quitar</button>
                                    }
                                </div>

                                <div class="row g-2">
                                    <div class="col-md-4">
                                        <label class="form-label">Tipo</label>
                                        <select class="form-select" value="@rule.Kind.ToString()" @onchange="@(e => SetRuleKind(rule, e.Value?.ToString()))">
                                            <option value="SingleDate">Un día</option>
                                            <option value="WeekdaysInRange">Días de la semana en rango</option>
                                            <option value="SpecificDates">Fechas específicas</option>
                                        </select>
                                    </div>

                                    <div class="col-md-4">
                                        <label class="form-label">Hora inicio</label>
                                        <input type="time" class="form-control" value="@rule.StartTimeText" @onchange="@(e => rule.StartTimeText = e.Value?.ToString() ?? rule.StartTimeText)" />
                                    </div>

                                    <div class="col-md-4">
                                        <label class="form-label">Hora fin</label>
                                        <input type="time" class="form-control" value="@rule.EndTimeText" @onchange="@(e => rule.EndTimeText = e.Value?.ToString() ?? rule.EndTimeText)" />
                                    </div>

                                    @if (rule.Kind == RecurrenceRuleKind.SingleDate)
                                    {
                                        <div class="col-md-6">
                                            <label class="form-label">Fecha</label>
                                            <input type="date" class="form-control" value="@FormatDateInput(rule.SingleDate)" @onchange="@(e => SetRuleDate(rule, e.Value?.ToString()))" />
                                        </div>
                                    }
                                    else if (rule.Kind == RecurrenceRuleKind.WeekdaysInRange)
                                    {
                                        <div class="col-md-6">
                                            <label class="form-label">Desde</label>
                                            <input type="date" class="form-control" value="@FormatDateInput(rule.RangeStartDate)" @onchange="@(e => SetRuleRangeStart(rule, e.Value?.ToString()))" />
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">Hasta</label>
                                            <input type="date" class="form-control" value="@FormatDateInput(rule.RangeEndDate)" @onchange="@(e => SetRuleRangeEnd(rule, e.Value?.ToString()))" />
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label">Días de la semana</label>
                                            <div class="d-flex flex-wrap gap-2">
                                                @foreach (var day in DaysOrdered)
                                                {
                                                    var isChecked = rule.Days.Contains(day);
                                                    <div class="form-check form-check-inline m-0" @key="day">
                                                        <input class="form-check-input" type="checkbox"
                                                               id="@($"rule_{i}_{day}")"
                                                               checked="@isChecked"
                                                               @onchange="@(e => ToggleRuleDay(rule, day, (bool)(e.Value ?? false)))" />
                                                        <label class="form-check-label" for="@($"rule_{i}_{day}")">@DayName(day)</label>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                    else if (rule.Kind == RecurrenceRuleKind.SpecificDates)
                                    {
                                        <div class="col-12">
                                            <label class="form-label">Fechas</label>
                                            <textarea class="form-control" rows="3"
                                                      placeholder="Una fecha por línea o separadas por coma:&#10;2026-07-03&#10;2026-07-04, 2026-07-05"
                                                      @onchange="@(e => SetRuleSpecificDates(rule, e.Value?.ToString()))">@rule.SpecificDatesText</textarea>
                                            <div class="form-text">Formato: AAAA-MM-DD (ej. 2026-07-03). Una por línea o separadas por coma.</div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
                <div class="col-12">
                    <label class="form-label">Notas</label>
                    <InputTextArea @bind-Value="ev.Notes" class="form-control" rows="3" />
                </div>
                <div class="col-12">
                    <div class="form-check">
                        <InputCheckbox @bind-Value="ev.Active" class="form-check-input" id="active" />
                        <label class="form-check-label" for="active">Activo</label>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-primary" disabled="@saving">@(saving ? "Guardando…" : "Guardar")</button>
                <a href="/events" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </EditForm>
    </div>
</div>
