@inject AssignmentService AssignmentSvc
@inject PersonService PersonSvc
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@Ev.EventName</MudText>
    </TitleContent>
    <DialogContent>
        <MudDivider Class="mb-3" Style="border-top-width:2px; opacity:0.6;" />
        <MudGrid Spacing="1">
            <MudItem xs="12">
                <MudText><strong>Cliente:</strong> @Ev.Company?.Name</MudText>
            </MudItem>
            <MudItem xs="12">
                <MudText><strong>Hora:</strong> @Ev.StartDateTime.ToLocalTime().ToString("MMM d, h:mm tt") – @Ev.EndDateTime.ToLocalTime().ToString("h:mm tt")</MudText>
            </MudItem>
            <MudItem xs="12">
                <MudText><strong>Requeridos:</strong> @FormatRequirements(Ev)</MudText>
            </MudItem>
            <MudItem xs="12">
                <MudText><strong>Asignados:</strong> @FormatAssigned(Ev)</MudText>
            </MudItem>
            <MudItem xs="12">
                <MudText>
                    <strong>Localización:</strong> @(Ev.Location?.Name ?? "—")
                </MudText>
            </MudItem>
            @if (!string.IsNullOrEmpty(Ev.Notes))
            {
                <MudItem xs="12">
                    <MudText><strong>Notas:</strong> @Ev.Notes</MudText>
                </MudItem>
            }
        </MudGrid>

        <MudDivider Class="my-3" Style="border-top-width:2px; opacity:0.6;" />
        <MudText Typo="Typo.subtitle2" Class="mb-2">Asignados</MudText>

        <div style="max-height:280px; overflow-y:auto;">
            @foreach (var a in Ev.Assignments)
            {
                <div class="d-flex align-items-center gap-2 mb-2">
                    <div style="flex:1; background-color:#DDF3E4; border-radius:6px; padding:6px 12px;">
                        <MudText Typo="Typo.body2" Style="color:#1B6E52; font-weight:500">@a.Person.FullName</MudText>
                    </div>
                    @if (Ev.Location?.Positions?.Any() == true)
                    {
                        <MudSelect T="int?" Value="@a.LocationPositionId"
                                   ValueChanged="@(p => ChangePosition(a, p))"
                                   Style="width:100px" Margin="Margin.Dense" Variant="Variant.Outlined"
                                   Placeholder="Posición">
                            <MudSelectItem T="int?" Value="@((int?)null)">—</MudSelectItem>
                            @foreach (var pos in Ev.Location.Positions.OrderBy(p => p.DisplayOrder).ThenBy(p => p.Name))
                            {
                                <MudSelectItem T="int?" Value="@((int?)pos.LocationPositionId)">@pos.Name</MudSelectItem>
                            }
                        </MudSelect>
                    }
                    <MudSelect T="int?" Value="@EffectiveRoleId(a)"
                               ValueChanged="@(r => ChangeRole(a, r))"
                               Style="width:10px" Margin="Margin.Dense" Variant="Variant.Outlined"
                               Placeholder="Rol">
                        @foreach (var role in _allRoles)
                        {
                            <MudSelectItem T="int?" Value="@((int?)role.RoleId)">@role.Name</MudSelectItem>
                        }
                    </MudSelect>
                    <MudSelect T="AssignmentStatus" Value="@a.Status"
                               ValueChanged="@(s => ChangeStatus(a, s))"
                               Style="width:10px" Margin="Margin.Dense" Variant="Variant.Outlined">
                        @foreach (var s in Enum.GetValues<AssignmentStatus>())
                        {
                            <MudSelectItem Value="@s">@s</MudSelectItem>
                        }
                    </MudSelect>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error"
                                   Size="Size.Small"
                                   OnClick="@(() => AskRemove(a.AssignmentId, a.Person.FullName))" />
                </div>
            }
            @if (!Ev.Assignments.Any())
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">No hay asignaciones aún.</MudText>
            }
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close" Variant="Variant.Text">Cerrar</MudButton>
        <MudButton OnClick="SendWhatsApp" Color="Color.Success" Variant="Variant.Outlined"
                   StartIcon="@Icons.Custom.Brands.WhatsApp">WhatsApp</MudButton>
        <MudButton Href="@($"/events/{Ev.EventId}")" Color="Color.Info"
                   Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Edit">Editar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public Event Ev { get; set; } = null!;
    [Parameter] public string CurrentUserId { get; set; } = "";

    private List<Role> _allRoles = new();

    protected override async Task OnInitializedAsync()
    {
        _allRoles = await PersonSvc.GetRolesAsync();
    }

    private void Close() => MudDialog.Cancel();
    private void SendWhatsApp() => MudDialog.Close(DialogResult.Ok("whatsapp"));

    private async Task ChangeStatus(Assignment a, AssignmentStatus status)
    {
        await AssignmentSvc.UpdateStatusAsync(a.AssignmentId, status, CurrentUserId);
        a.Status = status;
        MudDialog.Close(DialogResult.Ok("refresh"));
    }

    private async Task ChangePosition(Assignment a, int? locationPositionId)
    {
        await AssignmentSvc.UpdatePositionAsync(a.AssignmentId, locationPositionId, CurrentUserId);
        a.LocationPositionId = locationPositionId;
        MudDialog.Close(DialogResult.Ok("refresh"));
    }

    private async Task ChangeRole(Assignment a, int? roleId)
    {
        await AssignmentSvc.UpdateRoleAsync(a.AssignmentId, roleId, CurrentUserId);
        a.RoleId = roleId;
        a.Role = _allRoles.FirstOrDefault(r => r.RoleId == roleId);
        MudDialog.Close(DialogResult.Ok("refresh"));
    }

    // Falls back to the person's highest-rank role when the event has no explicit override yet.
    private static int? EffectiveRoleId(Assignment a) =>
        a.RoleId ?? AssignmentService.GetHighestRankRoleId(a.Person);

    private async Task AskRemove(int assignmentId, string personName)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Confirmar eliminación",
            $"Confirme remover a: {personName}",
            yesText: "Sí",
            cancelText: "No");

        if (confirmed == true)
        {
            await AssignmentSvc.DeleteAsync(assignmentId, CurrentUserId);
            MudDialog.Close(DialogResult.Ok("refresh"));
        }
    }

    private static string FormatRequirements(Event ev)
    {
        var otherLabel = string.IsNullOrWhiteSpace(ev.RequiredOtherLabel) ? "Otro" : ev.RequiredOtherLabel;
        return $"Sup: {ev.RequiredSupervisors} | Ujieres: {ev.RequiredUshers} | {otherLabel}: {ev.RequiredOther}";
    }

    private static string FormatAssigned(Event ev)
    {
        var otherLabel = string.IsNullOrWhiteSpace(ev.RequiredOtherLabel) ? "Otro" : ev.RequiredOtherLabel;
        int sup = 0, usher = 0, other = 0;
        foreach (var a in ev.Assignments)
        {
            var roleName = a.Role?.Name;
            if (roleName is null)
            {
                var roleId = EffectiveRoleId(a);
                roleName = a.Person.PersonRoles.FirstOrDefault(pr => pr.RoleId == roleId)?.Role?.Name;
            }
            if (roleName == "Supervisor") sup++;
            else if (roleName == "Ujier") usher++;
            else other++;
        }
        return $"Sup: {sup} | Ujieres: {usher} | {otherLabel}: {other}";
    }
}
