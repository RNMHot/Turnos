@page "/events-columns"
@attribute [Authorize(Policy = "AppAccess", Roles = "Gerencia,Admin")]
@rendermode InteractiveServer
@inject EventService EventSvc
@inject PersonService PersonSvc
@inject AssignmentService AssignmentSvc
@inject AuthenticationStateProvider AuthState
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject AppSettingsState SettingsState

<PageTitle>Events Board - Turnos</PageTitle>

<div class="events-columns-container">
    <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
        <MudText Typo="Typo.h5">Eventos Activos</MudText>
    </div>

    <div class="events-columns-board">
        <div class="personnel-panel">
            <div class="panel-header">
                <MudToggleGroup T="string" Value="@personnelFilter" ValueChanged="OnPersonnelFilterChanged"
                                 Color="Color.Primary" Size="Size.Small" Delimiters="false" Class="mb-1 personnel-filter-toggle">
                    <MudToggleItem Value="@("Regular")" Text="Regular" />
                    <MudToggleItem Value="@("Masivos")" Text="Masivos" />
                </MudToggleGroup>
                <MudTextField T="string" Value="@personSearch" ValueChanged="OnPersonSearchChanged"
                              Placeholder="Búsqueda…" Immediate="true" Clearable="true"
                              Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-1" />
            </div>
            <div id="panelbody" class="panel-body">
                @if (filteredPersonnel.Count == 0)
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="px-1">No hay personal disponible.</MudText>
                }
                else
                {
                    @foreach (var person in filteredPersonnel)
                    {
                        <div class="person-chip @GetRoleClass(person)"
                             draggable="true"
                             @ondragstart="() => OnPersonDragStart(person)"
                             title="@GetRoleLabel(person)">
                            <i class="bi bi-person-fill me-1"></i>
                            <span>@person.FullName</span>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="events-columns-wrapper">
            @if (activeEvents.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Class="border">No hay eventos activos para mostrar.</MudAlert>
            }
            else
            {
                <div class="events-columns-grid">
                    @foreach (var ev in activeEvents)
                    {
                        var localStart = SettingsState.ToDisplay(ev.StartDateTime);
                        var localEnd = SettingsState.ToDisplay(ev.EndDateTime);

                        <section class="event-column">
                            <header class="event-column-header @GetEventClass(ev)" style="cursor:pointer" @onclick="() => OpenEventDetail(ev)">
                                <div class="event-title">@ev.EventName</div>
                                <div class="event-meta">@localStart.ToString("ddd, MMM d")</div>
                                <div class="event-meta">@localStart.ToString("h:mm tt") - @localEnd.ToString("h:mm tt")</div>
                                <div class="event-meta">@(ev.Company?.Name ?? "-")</div>
                                <div class="event-meta">@FormatRequirements(ev)</div>
                            </header>

                            <div class="event-column-body @(draggedPerson is not null ? "drop-target-active" : "")"
                                 @ondragover="OnDragOver"
                                 @ondragover:preventDefault="true"
                                 @ondrop:preventDefault="true"
                                 @ondrop="() => OnDropOnEvent(ev)"
                                 @onclick="() => OnDropZoneClick(ev)">
                                <div class="small text-muted mb-2 drop-zone-hint">
                                    <i class="bi bi-person-plus me-1"></i>Arrastrar o clic para asignar
                                </div>

                                @if (ev.Assignments.Count == 0)
                                {
                                    <div class="small text-muted">No hay asignaciones aún</div>
                                }
                                else
                                {
                                    @foreach (var a in ev.Assignments)
                                    {
                                        <div class="assignment-row d-flex align-items-center justify-content-between gap-2"
                                             @onclick:stopPropagation="true">
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="assignment-name">@a.Person.FullName</span>
                                                <MudChip T="string" Color="@GetStatusColor(a.Status)"
                                                         Size="Size.Small" Variant="Variant.Filled" Class="ma-0">
                                                    @a.Status
                                                </MudChip>
                                            </div>
                                            <span @onclick:stopPropagation="true">
                                                <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error"
                                                               Size="Size.Small"
                                                               OnClick="@(() => ConfirmRemoveAssignment(a.AssignmentId, a.Person.FullName))" />
                                            </span>
                                        </div>
                                    }
                                }
                            </div>
                        </section>
                    }
                </div>
            }
        </div>
    </div>
</div>

<MessageModal Show="showMessageModal" EventId="messageEventId" OnClose="CloseMessageModal" />

@code {
    private List<Event> activeEvents = new();
    private List<Person> availablePersonnel = new();
    private List<Person> filteredPersonnel = new();
    private string personSearch = "";
    private string personnelFilter = "Regular";
    private Person? draggedPerson;
    private bool showMessageModal;
    private int? messageEventId;
    private string currentUserId = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        currentUserId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
        await LoadData();
    }

    private async Task LoadData()
    {
        activeEvents = await EventSvc.GetActiveWithAssignmentsAsync();
        await LoadPersonnel();
    }

    private async Task LoadPersonnel()
    {
        availablePersonnel = await PersonSvc.GetAllWithAvailabilityAsync(active: true, isMassGroup: personnelFilter == "Masivos");
        FilterPersonnel();
    }

    private async Task OnPersonnelFilterChanged(string value)
    {
        personnelFilter = value;
        await LoadPersonnel();
    }

    private void FilterPersonnel()
    {
        filteredPersonnel = string.IsNullOrWhiteSpace(personSearch)
            ? availablePersonnel
            : availablePersonnel
                .Where(p => p.FullName.Contains(personSearch, StringComparison.OrdinalIgnoreCase))
                .ToList();
    }

    private void OnPersonSearchChanged(string val)
    {
        personSearch = val;
        FilterPersonnel();
    }

    private void OnPersonDragStart(Person person) => draggedPerson = person;

    private static void OnDragOver(DragEventArgs _) { }

    private async Task OnDropOnEvent(Event ev)
    {
        if (draggedPerson is null)
            return;

        var person = draggedPerson;
        draggedPerson = null;
        await AssignPersonToEvent(ev, person);
    }

    private async Task<bool> AssignPersonToEvent(Event ev, Person person)
    {
        var assignment = new Assignment
        {
            EventId = ev.EventId,
            PersonId = person.PersonId,
            StartDateTime = ev.StartDateTime,
            EndDateTime = ev.EndDateTime,
            Status = AssignmentStatus.Candidato
        };

        var (success, errMsg) = await AssignmentSvc.CreateAsync(assignment, currentUserId);

        if (success)
        {
            Snackbar.Add($"Asignado a {ev.EventName}", Severity.Success);
            await LoadData();
            StateHasChanged();
        }
        else
        {
            Snackbar.Add(errMsg ?? "Error al asignar", Severity.Error);
        }

        return success;
    }

    private async Task ConfirmRemoveAssignment(int assignmentId, string personName)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Confirmar eliminación",
            $"Confirme remover a: {personName}",
            yesText: "Sí",
            cancelText: "No");

        if (confirmed == true)
        {
            await AssignmentSvc.DeleteAsync(assignmentId, currentUserId);
            await LoadData();
        }
    }

    private async Task OnDropZoneClick(Event ev)
    {
        if (draggedPerson is not null) return;

        var parameters = new DialogParameters<PersonPickerDialog>
        {
            { x => x.EventName, ev.EventName },
            { x => x.Personnel, availablePersonnel },
            { x => x.OnPick, (Func<Person, Task<bool>>)(person => AssignPersonToEvent(ev, person)) }
        };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        await DialogService.ShowAsync<PersonPickerDialog>("", parameters, options);
    }

    private async Task OpenEventDetail(Event ev)
    {
        var parameters = new DialogParameters<EventColumnDetailDialog>
        {
            { x => x.Ev, ev },
            { x => x.CurrentUserId, currentUserId }
        };
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseButton = true
        };
        var dialog = await DialogService.ShowAsync<EventColumnDetailDialog>(ev.EventName, parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: string action })
        {
            if (action == "whatsapp")
            {
                messageEventId = ev.EventId;
                showMessageModal = true;
            }
            else if (action == "refresh")
            {
                await LoadData();
            }
        }
    }

    private void CloseMessageModal()
    {
        showMessageModal = false;
        messageEventId = null;
    }

    private static string GetRoleClass(Person p)
    {
        var roles = p.PersonRoles.Select(r => r.Role?.Name).ToList();
        bool isUsher = roles.Contains("Ujier");
        bool isSup = roles.Contains("Supervisor");
        return (isUsher, isSup) switch
        {
            (true, true) => "role-both",
            (false, true) => "role-supervisor",
            _ => "role-usher"
        };
    }

    private static string GetRoleLabel(Person p)
    {
        var roles = p.PersonRoles.Select(r => r.Role?.Name ?? "").Where(r => r != "User");
        return string.Join(" / ", roles);
    }

    private static string GetEventClass(Event ev)
    {
        var requiredTotal = ev.RequiredSupervisors + ev.RequiredUshers + ev.RequiredOther;
        var assignedTotal = ev.Assignments.Count(a =>
            a.Status == AssignmentStatus.Disponible ||
            a.Status == AssignmentStatus.Asignado ||
            a.Status == AssignmentStatus.Confirmado);

        return assignedTotal >= requiredTotal ? "event-staffed" : "event-unstaffed";
    }

    private static Color GetStatusColor(AssignmentStatus status) => status switch
    {
        AssignmentStatus.Confirmado => Color.Success,
        AssignmentStatus.Asignado   => Color.Primary,
        AssignmentStatus.Disponible => Color.Info,
        AssignmentStatus.Ofrecido   => Color.Warning,
        AssignmentStatus.Candidato  => Color.Default,
        _ => Color.Default
    };

    private static string FormatRequirements(Event ev)
    {
        var otherLabel = string.IsNullOrWhiteSpace(ev.RequiredOtherLabel) ? "Otro" : ev.RequiredOtherLabel;
        return $"Sup: {ev.RequiredSupervisors} | Ushers: {ev.RequiredUshers} | {otherLabel}: {ev.RequiredOther}";
    }
}
