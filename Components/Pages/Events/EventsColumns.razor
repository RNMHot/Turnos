@page "/events-columns"
@attribute [Authorize(Policy = "AppAccess", Roles = "Gerencia,Admin")]
@rendermode InteractiveServer
@inject EventService EventSvc
@inject PersonService PersonSvc
@inject AssignmentService AssignmentSvc
@inject AuthenticationStateProvider AuthState

<PageTitle>Events Board - Turnos</PageTitle>

<div class="events-columns-container">
    <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
        <h4 class="m-0">Eventos Activos</h4>
        @if (dropMessage is not null)
        {
            <span class="badge @(dropSuccess ? "bg-success" : "bg-danger")">@dropMessage</span>
        }
    </div>

    <div class="events-columns-board">
        <div class="personnel-panel">
            <div class="panel-header">
                <strong>Personal Disponible</strong>
                <input class="form-control form-control-sm mt-1"
                       placeholder="Búsqueda..."
                       @bind="personSearch"
                       @bind:event="oninput"
                       @bind:after="FilterPersonnel" />
            </div>
            <div id="panelbody" class="panel-body">
                @if (filteredPersonnel.Count == 0)
                {
                    <div class="text-muted small px-1">No hay personal disponible.</div>
                }
                else
                {
                    @foreach (var person in filteredPersonnel)
                    {
                        <div class="person-chip @GetRoleClass(person)"
                             draggable="true"
                             @ondragstart="() => OnPersonDragStart(person)"
                             title="@GetRoleLabel(person)">
                            <i class="bi bi-person-fill me-1"></i>
                            <span>@person.FullName</span>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="events-columns-wrapper">
            @if (activeEvents.Count == 0)
            {
                <div class="alert alert-light border">No hay eventos activos para mostrar.</div>
            }
            else
            {
                <div class="events-columns-grid">
                    @foreach (var ev in activeEvents)
                    {
                        var localStart = ev.StartDateTime.ToLocalTime();
                        var localEnd = ev.EndDateTime.ToLocalTime();

                        <section class="event-column">
                            <header class="event-column-header @GetEventClass(ev)" style="cursor:pointer" @onclick="() => OpenEventDetail(ev)">
                                <div class="event-title">@ev.EventName</div>
                                <div class="event-meta">@localStart.ToString("ddd, MMM d")</div>
                                <div class="event-meta">@localStart.ToString("h:mm tt") - @localEnd.ToString("h:mm tt")</div>
                                <div class="event-meta">@(ev.Company?.Name ?? "-")</div>
                                <div class="event-meta">@FormatRequirements(ev)</div>
                            </header>

                            <div class="event-column-body @(draggedPerson is not null ? "drop-target-active" : "")"
                                   @ondragover="OnDragOver"
                                 @ondragover:preventDefault="true"
                                   @ondrop:preventDefault="true"
                                 @ondrop="() => OnDropOnEvent(ev)"
                                 @onclick="() => OnDropZoneClick(ev)">
                                <div class="small text-muted mb-2 drop-zone-hint">
                                    <i class="bi bi-person-plus me-1"></i>Arrastrar o clic para asignar
                                </div>

                                @if (ev.Assignments.Count == 0)
                                {
                                    <div class="small text-muted">No hay asignaciones aún</div>
                                }
                                else
                                {
                                    @foreach (var a in ev.Assignments)
                                    {
                                        <div class="assignment-row d-flex align-items-center justify-content-between gap-2"
                                             @onclick:stopPropagation="true">
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="assignment-name">@a.Person.FullName</span>
                                                <span class="badge @GetStatusBadge(a.Status)">@a.Status</span>
                                            </div>
                                            <button class="btn btn-sm btn-outline-danger"
                                                    title="Eliminar asignación"
                                                    @onclick="() => AskRemoveAssignment(a.AssignmentId, a.Person.FullName)"
                                                    @onclick:stopPropagation="true">
                                                <i class="bi bi-x"></i>
                                            </button>
                                        </div>
                                    }
                                }
                            </div>
                        </section>
                    }
                </div>
            }
        </div>
    </div>
</div>

@if (selectedEvent is not null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.4)">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@selectedEvent.EventName</h5>
                    <button class="btn-close" @onclick="() => selectedEvent = null"></button>
                </div>
                <div class="modal-body">
                    <p><strong>Cliente:</strong> @selectedEvent.Company?.Name</p>
                    <p><strong>Hora:</strong> @selectedEvent.StartDateTime.ToLocalTime().ToString("MMM d, h:mm tt") – @selectedEvent.EndDateTime.ToLocalTime().ToString("h:mm tt")</p>
                    <p><strong>Requeridos:</strong> @FormatRequirements(selectedEvent)</p>
                    <p>
                        <strong>Localización:</strong> @(selectedEvent.Location?.Name ?? "—")
                        @if (selectedEvent.Location?.Latitude.HasValue == true)
                        {
                            <a href="https://maps.google.com/?q=@selectedEvent.Location.Latitude,@selectedEvent.Location.Longitude"
                               target="_blank" rel="noopener" class="ms-2 small text-muted text-decoration-none">
                                <i class="bi bi-pin-map"></i> Mapa
                            </a>
                        }
                    </p>
                    @if (!string.IsNullOrEmpty(selectedEvent.Notes))
                    {
                        <p><strong>Notas:</strong> @selectedEvent.Notes</p>
                    }
                    <hr />
                    <h6>Asignados</h6>
                    @foreach (var a in selectedEvent.Assignments)
                    {
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="@GetRoleClass(a.Person) px-2 py-1 rounded small flex-grow-1">@a.Person.FullName</span>
                            <select class="form-select form-select-sm" style="width:130px"
                                    value="@a.Status.ToString()"
                                    @onchange="async e => await ChangeStatus(a, e.Value?.ToString() ?? string.Empty)">
                                <option value="Candidato">Candidato</option>
                                <option value="Ofrecido">Ofrecido</option>
                                <option value="Disponible">Disponible</option>
                                <option value="Asignado">Asignado</option>
                                <option value="Confirmado">Confirmado</option>
                            </select>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => AskRemoveAssignment(a.AssignmentId, a.Person.FullName)">
                                <i class="bi bi-x"></i>
                            </button>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <a href="/events/@selectedEvent.EventId" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-pencil me-1"></i> Editar Evento
                    </a>
                    <button class="btn btn-outline-success btn-sm" @onclick="OpenMessageModal">
                        <i class="bi bi-whatsapp me-1"></i> Enviar Mensaje
                    </button>
                    <button class="btn btn-secondary" @onclick="() => selectedEvent = null">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
}

<MessageModal Show="showMessageModal" EventId="selectedEvent?.EventId" OnClose="CloseMessageModal" />

@if (confirmRemoveAssignmentId.HasValue)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header py-2">
                    <h6 class="modal-title">Confirmar eliminación</h6>
                    <button class="btn-close" @onclick="CancelRemoveAssignment"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-0">Confirme remover a: <strong>@confirmRemovePersonName</strong></p>
                </div>
                <div class="modal-footer py-2">
                    <button class="btn btn-secondary btn-sm" @onclick="CancelRemoveAssignment">No</button>
                    <button class="btn btn-danger btn-sm" @onclick="ConfirmRemoveAssignment">Sí</button>
                </div>
            </div>
        </div>
    </div>
}

@if (pickingForEvent is not null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.4)" @onclick="ClosePicker">
        <div class="modal-dialog modal-sm" @onclick:stopPropagation="true">
            <div class="modal-content">
                <div class="modal-header py-2">
                    <h6 class="modal-title">Asignar a @pickingForEvent.EventName</h6>
                    <button class="btn-close" @onclick="ClosePicker"></button>
                </div>
                <div class="modal-body p-2">
                    <input class="form-control form-control-sm mb-2"
                           placeholder="Búsqueda..."
                           @bind="personPickerSearch"
                           @bind:event="oninput"
                           @bind:after="FilterPickerPersonnel" />
                    <div style="max-height:300px;overflow-y:auto">
                        @if (pickerPersonnel.Count == 0)
                        {
                            <div class="text-muted small px-1">Sin resultados</div>
                        }
                        else
                        {
                            @foreach (var person in pickerPersonnel)
                            {
                                <div class="person-chip @GetRoleClass(person) mb-1"
                                     style="cursor:pointer"
                                     @onclick="() => AssignPersonFromPicker(person)"
                                     title="@GetRoleLabel(person)">
                                    <i class="bi bi-person-fill me-1"></i>
                                    <span>@person.FullName</span>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Event> activeEvents = new();
    private List<Person> availablePersonnel = new();
    private List<Person> filteredPersonnel = new();
    private string personSearch = "";
    private Person? draggedPerson;
    private Event? selectedEvent;
    private bool showMessageModal;
    private string? dropMessage;
    private bool dropSuccess;
    private string currentUserId = "";
    private Event? pickingForEvent;
    private string personPickerSearch = "";
    private List<Person> pickerPersonnel = new();
    private int? confirmRemoveAssignmentId;
    private string confirmRemovePersonName = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        currentUserId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
        await LoadData();
    }

    private async Task LoadData()
    {
        activeEvents = await EventSvc.GetActiveWithAssignmentsAsync();

        var allPeople = await PersonSvc.GetAllWithAvailabilityAsync(active: true);
        availablePersonnel = allPeople;

        FilterPersonnel();
    }

    private void FilterPersonnel()
    {
        filteredPersonnel = string.IsNullOrWhiteSpace(personSearch)
            ? availablePersonnel
            : availablePersonnel
                .Where(p => p.FullName.Contains(personSearch, StringComparison.OrdinalIgnoreCase))
                .ToList();
    }

    private void OnPersonDragStart(Person person) => draggedPerson = person;

    private static void OnDragOver(DragEventArgs _) { }

    private async Task OnDropOnEvent(Event ev)
    {
        if (draggedPerson is null)
        {
            return;
        }

        var assignment = new Assignment
        {
            EventId = ev.EventId,
            PersonId = draggedPerson.PersonId,
            StartDateTime = ev.StartDateTime,
            EndDateTime = ev.EndDateTime,
            Status = AssignmentStatus.Candidato
        };

        var (success, errMsg) = await AssignmentSvc.CreateAsync(assignment, currentUserId);
        dropSuccess = success;
        dropMessage = success
            ? $"Asignado {draggedPerson.FullName} a {ev.EventName}"
            : errMsg;
        draggedPerson = null;

        if (success)
        {
            await LoadData();
        }

        _ = Task.Delay(4000).ContinueWith(_ =>
        {
            dropMessage = null;
            InvokeAsync(StateHasChanged);
        });
    }

    private void AskRemoveAssignment(int assignmentId, string personName)
    {
        confirmRemoveAssignmentId = assignmentId;
        confirmRemovePersonName = personName;
    }

    private void CancelRemoveAssignment()
    {
        confirmRemoveAssignmentId = null;
        confirmRemovePersonName = "";
    }

    private async Task ConfirmRemoveAssignment()
    {
        if (confirmRemoveAssignmentId.HasValue)
            await RemoveAssignment(confirmRemoveAssignmentId.Value);
        confirmRemoveAssignmentId = null;
        confirmRemovePersonName = "";
    }

    private async Task RemoveAssignment(int assignmentId)
    {
        await AssignmentSvc.DeleteAsync(assignmentId, currentUserId);
        await LoadData();
        if (selectedEvent is not null)
            selectedEvent = activeEvents.FirstOrDefault(e => e.EventId == selectedEvent.EventId);
    }

    private void OnDropZoneClick(Event ev)
    {
        if (draggedPerson is not null) return;
        pickingForEvent = ev;
        personPickerSearch = "";
        pickerPersonnel = availablePersonnel.ToList();
    }

    private void FilterPickerPersonnel()
    {
        pickerPersonnel = string.IsNullOrWhiteSpace(personPickerSearch)
            ? availablePersonnel.ToList()
            : availablePersonnel
                .Where(p => p.FullName.Contains(personPickerSearch, StringComparison.OrdinalIgnoreCase))
                .ToList();
    }

    private async Task AssignPersonFromPicker(Person person)
    {
        if (pickingForEvent is null) return;
        draggedPerson = person;
        await OnDropOnEvent(pickingForEvent);
        pickingForEvent = null;
        personPickerSearch = "";
    }

    private void ClosePicker()
    {
        pickingForEvent = null;
        personPickerSearch = "";
    }

    private void OpenEventDetail(Event ev) => selectedEvent = ev;
    private void OpenMessageModal() => showMessageModal = true;
    private void CloseMessageModal() => showMessageModal = false;

    private async Task ChangeStatus(Assignment a, string statusStr)
    {
        if (Enum.TryParse<AssignmentStatus>(statusStr, out var status))
        {
            await AssignmentSvc.UpdateStatusAsync(a.AssignmentId, status, currentUserId);
            a.Status = status;
        }
    }

    private static string GetRoleClass(Person p)
    {
        var roles = p.PersonRoles.Select(r => r.Role?.Name).ToList();
        bool isUsher = roles.Contains("Usher");
        bool isSup = roles.Contains("Supervisor");
        return (isUsher, isSup) switch
        {
            (true, true) => "role-both",
            (false, true) => "role-supervisor",
            _ => "role-usher"
        };
    }

    private static string GetRoleLabel(Person p)
    {
        var roles = p.PersonRoles.Select(r => r.Role?.Name ?? "").Where(r => r != "User");
        return string.Join(" / ", roles);
    }

    private static string GetEventClass(Event ev)
    {
        var requiredTotal = ev.RequiredSupervisors + ev.RequiredUshers + ev.RequiredOther;
        var assignedTotal = ev.Assignments.Count(a =>
            a.Status == AssignmentStatus.Disponible ||
            a.Status == AssignmentStatus.Asignado ||
            a.Status == AssignmentStatus.Confirmado);

        return assignedTotal >= requiredTotal
            ? "event-staffed"
            : "event-unstaffed";
    }

    private static string GetStatusBadge(AssignmentStatus status) => status switch
    {
        AssignmentStatus.Confirmado => "bg-success",
        AssignmentStatus.Asignado => "bg-primary",
        AssignmentStatus.Disponible => "bg-info text-dark",
        AssignmentStatus.Ofrecido => "bg-warning text-dark",
        AssignmentStatus.Candidato => "bg-secondary",
        _ => "bg-secondary"
    };

    private static string FormatRequirements(Event ev)
    {
        var otherLabel = string.IsNullOrWhiteSpace(ev.RequiredOtherLabel) ? "Otro" : ev.RequiredOtherLabel;
        return $"Sup: {ev.RequiredSupervisors} | Ushers: {ev.RequiredUshers} | {otherLabel}: {ev.RequiredOther}";
    }
}
