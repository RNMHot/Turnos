@page "/"
@attribute [Authorize(Policy = "AppAccess", Roles = "Gerencia,Admin")]
@rendermode InteractiveServer
@inject EventService EventSvc
@inject PersonService PersonSvc
@inject AssignmentService AssignmentSvc
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav
@using System.Globalization

<PageTitle>Itinerario — Turnos</PageTitle>

<div class="schedule-container">
    <!-- Top toolbar -->
    <div class="d-flex align-items-center gap-2 mb-3">
        <button class="btn btn-outline-secondary btn-sm" @onclick="PrevWeek"><i class="bi bi-chevron-left"></i></button>
        <button class="btn btn-outline-primary btn-sm" @onclick="GoToday">Hoy</button>
        <button class="btn btn-outline-secondary btn-sm" @onclick="NextWeek"><i class="bi bi-chevron-right"></i></button>
        <span class="fw-semibold">@WeekLabel</span>
        @if (dropMessage is not null)
        {
            <span class="ms-3 badge @(dropSuccess ? "bg-success" : "bg-danger")">@dropMessage</span>
        }
    </div>

    <div class="schedule-board">
        <!-- Left panel: personnel list -->
        <div class="personnel-panel">
            <div class="panel-header">
                <strong>Personal Disponible</strong>
                <input class="form-control form-control-sm mt-1" 
                    placeholder="Búsqueda…" 
                    @bind="personSearch" 
                    @bind:event="oninput" 
                    @bind:after="FilterPersonnel" />
            </div>
            <div id="panelbody" class="panel-body">
                @if (filteredPersonnel.Count == 0)
                {
                    <div class="text-muted small px-1">No hay personal disponible.</div>
                }
                else
                {
                    @foreach (var person in filteredPersonnel)
                    {
                        <div class="person-chip @GetRoleClass(person)"
                            draggable="true"
                            @ondragstart="() => OnPersonDragStart(person)"
                            @ondblclick="() => OpenPersonAvailability(person.PersonId)"
                            title="@GetRoleLabel(person)">
                            <i class="bi bi-person-fill me-1"></i>
                            <span>@person.FullName</span>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Weekly grid -->
        <div class="week-grid-wrapper">
            <div class="week-grid">
                <!-- Day headers -->
                <div class="grid-corner"></div>
                @for (int d = 0; d < 7; d++)
                {
                    var day = weekStart.AddDays(d);
                    var isToday = day.Date == DateTime.Today;
                    <div class="day-header @(isToday ? "hoy" : "")">
                        <div class="day-name">@day.ToString("ddd", new CultureInfo("es-ES")).ToUpper()</div>
                        <div class="day-date">@day.ToString("MMM d")</div>
                    </div>
                }

                <!-- Time slots -->
                @for (int hour = 5; hour <= 23; hour++)
                {
                    <div class="time-label">@DateTime.Today.AddHours(hour).ToString("h tt")</div>
                    @for (int d = 0; d < 7; d++)
                    {
                        var day = weekStart.AddDays(d);
                        var slotStart = day.Date.AddHours(hour);
                        var slotEnd = slotStart.AddHours(1);
                        var slotEvents = GetEventsForSlot(day, hour);

                        <div class="time-slot @(draggedPerson != null ? "drop-target-active" : "")"
                             @ondragover:preventDefault="true"
                             @ondrop="() => OnDropOnSlot(slotStart)"
                             @ondblclick="() => OpenNewEvent(slotStart)">
                            @foreach (var ev in slotEvents)
                            {
                                var heightPx = GetEventHeightPx(ev);
                                var posStyle = GetEventPositionStyle(ev);
                                <div class="event-block @GetEventClass(ev)"
                                     style="height:@(heightPx.ToString("F0"))px;@posStyle"
                                     @ondblclick:stopPropagation="true">
                                    <div class="event-info-area" @onclick="() => OpenEventDetail(ev)">
                                        <div class="event-name">@ev.EventName</div>
                                        <div class="event-company small">@ev.Company?.Name</div>
                                        <div class="small text-opacity-75">
                                            @ev.StartDateTime.ToLocalTime().ToString("h:mm tt") – @ev.EndDateTime.ToLocalTime().ToString("h:mm tt")
                                        </div>
                                        <div class="small text-opacity-75">
                                            @FormatRequirements(ev)
                                        </div>
                                    </div>
                                    <div class="event-assignments small mt-1"
                                         style="cursor:pointer"
                                         @onclick="() => OnAssignmentsAreaClick(ev)"
                                         @onclick:stopPropagation="true">
                                        <div class="text-muted" style="font-size:10px">
                                            <i class="bi bi-person-plus me-1"></i>Arrastrar o clic para asignar
                                        </div>
                                        @foreach (var a in ev.Assignments)
                                        {
                                            <div class="assignment-badge" @onclick:stopPropagation="true">@a.Person.FullName</div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

<!-- Event detail modal -->
@if (selectedEvent is not null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.4)">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@selectedEvent.EventName</h5>
                    <button class="btn-close" @onclick="() => selectedEvent = null"></button>
                </div>
                <div class="modal-body">
                    <p><strong>Cliente:</strong> @selectedEvent.Company?.Name</p>
                    <p><strong>Hora:</strong> @selectedEvent.StartDateTime.ToLocalTime().ToString("MMM d, h:mm tt") – @selectedEvent.EndDateTime.ToLocalTime().ToString("h:mm tt")</p>
                    <p><strong>Requeridos:</strong> @FormatRequirements(selectedEvent)</p>
                    <p>
                        <strong>Localización:</strong> @(selectedEvent.Location?.Name ?? "—")
                    </p>
                    @if (!string.IsNullOrEmpty(selectedEvent.Notes))
                    {
                        <p><strong>Notas:</strong> @selectedEvent.Notes</p>
                    }
                    <hr />
                    <h6>Asignados</h6>
                    @foreach (var a in selectedEvent.Assignments)
                    {
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="@GetRoleClass(a.Person) px-2 py-1 rounded small flex-grow-1">@a.Person.FullName</span>
                            <select class="form-select form-select-sm" style="width:130px"
                                    value="@a.Status.ToString()"
                                    @onchange="async e => await ChangeStatus(a, e.Value?.ToString() ?? string.Empty)">
                                <option value="Candidato">Candidato</option>
                                <option value="Ofrecido">Ofrecido</option>
                                <option value="Disponible">Disponible</option>
                                <option value="Asignado">Asignado</option>
                                <option value="Confirmado">Confirmado</option>
                            </select>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveAssignment(a.AssignmentId)">
                                <i class="bi bi-x"></i>
                            </button>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <a href="/events/@selectedEvent.EventId" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-pencil me-1"></i> Editar Evento
                    </a>
                    <button class="btn btn-outline-success btn-sm" @onclick="OpenMessageModal">
                        <i class="bi bi-whatsapp me-1"></i> Enviar Mensaje
                    </button>
                    <button class="btn btn-secondary" @onclick="() => selectedEvent = null">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
}

<MessageModal Show="showMessageModal" EventId="selectedEvent?.EventId" OnClose="CloseMessageModal" />

@if (pickingForEvent is not null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.4)" @onclick="ClosePicker">
        <div class="modal-dialog modal-sm" @onclick:stopPropagation="true">
            <div class="modal-content">
                <div class="modal-header py-2">
                    <h6 class="modal-title">Asignar a @pickingForEvent.EventName</h6>
                    <button class="btn-close" @onclick="ClosePicker"></button>
                </div>
                <div class="modal-body p-2">
                    <input class="form-control form-control-sm mb-2"
                           placeholder="Búsqueda..."
                           @bind="personPickerSearch"
                           @bind:event="oninput"
                           @bind:after="FilterPickerPersonnel" />
                    <div style="max-height:300px;overflow-y:auto">
                        @if (pickerPersonnel.Count == 0)
                        {
                            <div class="text-muted small px-1">Sin resultados</div>
                        }
                        else
                        {
                            @foreach (var person in pickerPersonnel)
                            {
                                <div class="person-chip @GetRoleClass(person) mb-1"
                                     style="cursor:pointer"
                                     @onclick="() => AssignPersonFromPicker(person)"
                                     title="@GetRoleLabel(person)">
                                    <i class="bi bi-person-fill me-1"></i>
                                    <span>@person.FullName</span>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private DateTime weekStart;
    private List<Event> weekEvents = new();
    private List<Person> allPersonnel = new();
    private List<Person> filteredPersonnel = new();
    private string personSearch = "";
    private Person? draggedPerson;
    private Event? selectedEvent;
    private bool showMessageModal;
    private string? dropMessage;
    private bool dropSuccess;
    private string currentUserId = "";
    private Event? pickingForEvent;
    private string personPickerSearch = "";
    private List<Person> pickerPersonnel = new();

    protected override async Task OnInitializedAsync()
    {
        weekStart = GetMonday(DateTime.Today);
        var authState = await AuthState.GetAuthenticationStateAsync();
        currentUserId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
        await LoadData();
    }

    private async Task LoadData()
    {
        weekEvents = await EventSvc.GetForWeekAsync(weekStart);

        if (!weekEvents.Any())
        {
            var allActiveEvents = await EventSvc.GetActiveWithAssignmentsAsync();
            var nearestEvent = allActiveEvents
                .OrderBy(e => Math.Abs((NormalizeToLocal(e.StartDateTime) - DateTime.Now).TotalMinutes))
                .FirstOrDefault();

            if (nearestEvent is not null)
            {
                weekStart = GetMonday(NormalizeToLocal(nearestEvent.StartDateTime));
                weekEvents = await EventSvc.GetForWeekAsync(weekStart);
            }
        }

        allPersonnel = await PersonSvc.GetAllAsync(active: true);
        FilterPersonnel();
        ComputeAllLayouts();
    }

    private void FilterPersonnel()
    {
        filteredPersonnel = string.IsNullOrWhiteSpace(personSearch)
            ? allPersonnel
            : allPersonnel.Where(p => p.FullName.Contains(personSearch, StringComparison.OrdinalIgnoreCase)).ToList();
    }

    private string WeekLabel => $"{weekStart:MMM d} – {weekStart.AddDays(6):MMM d, yyyy}";

    private async Task PrevWeek() { weekStart = weekStart.AddDays(-7); await LoadData(); }
    private async Task NextWeek() { weekStart = weekStart.AddDays(7); await LoadData(); }
    private async Task GoToday() { weekStart = GetMonday(DateTime.Today); await LoadData(); }

    private static DateTime GetMonday(DateTime date)
    {
        int diff = (7 + (date.DayOfWeek - DayOfWeek.Monday)) % 7;
        return date.AddDays(-diff).Date;
    }

    private List<Event> GetEventsForSlot(DateTime day, int hour)
    {
        return weekEvents.Where(e =>
        {
            var start = NormalizeToLocal(e.StartDateTime);
            return start.Date == day.Date && start.Hour == hour;
        }).ToList();
    }

    // Pixel height = duration × slot height, so event block spans its full time range
    private static double GetEventHeightPx(Event ev)
    {
        const int slotPx = 56;
        var duration = NormalizeToLocal(ev.EndDateTime) - NormalizeToLocal(ev.StartDateTime);
        return Math.Max(slotPx - 6, duration.TotalHours * slotPx - 6);
    }

    private void OnPersonDragStart(Person person) => draggedPerson = person;

    private async Task OnDropOnSlot(DateTime slotStart)
    {
        if (draggedPerson is null) return;

        // Compare in local time so drop targets match displayed event positions
        var ev = weekEvents.FirstOrDefault(e =>
            NormalizeToLocal(e.StartDateTime) <= slotStart &&
            NormalizeToLocal(e.EndDateTime) > slotStart);
        if (ev is null) { draggedPerson = null; return; }

        var assignment = new Assignment
        {
            EventId = ev.EventId,
            PersonId = draggedPerson.PersonId,
            StartDateTime = ev.StartDateTime,
            EndDateTime = ev.EndDateTime,
            Status = AssignmentStatus.Candidato
        };

        var (success, errMsg) = await AssignmentSvc.CreateAsync(assignment, currentUserId);
        dropSuccess = success;
        dropMessage = success ? $"Asignado {draggedPerson.FullName} a {ev.EventName}" : errMsg;
        draggedPerson = null;

        if (success) await LoadData();

        _ = Task.Delay(4000).ContinueWith(_ => { dropMessage = null; InvokeAsync(StateHasChanged); });
    }

    private void OpenNewEvent(DateTime slotStart) => Nav.NavigateTo($"/events/new?start={slotStart:yyyy-MM-ddTHH:mm}");
    private void OpenPersonAvailability(int personId) => Nav.NavigateTo($"/personnel/{personId}/availability");

    private void OpenEventDetail(Event ev) => selectedEvent = ev;

    private async Task RemoveAssignment(int id)
    {
        await AssignmentSvc.DeleteAsync(id, currentUserId);
        await LoadData();
        if (selectedEvent is not null)
            selectedEvent = weekEvents.FirstOrDefault(e => e.EventId == selectedEvent.EventId);
    }

    private void OnAssignmentsAreaClick(Event ev)
    {
        if (draggedPerson is not null) return;
        pickingForEvent = ev;
        personPickerSearch = "";
        pickerPersonnel = allPersonnel.ToList();
    }

    private void FilterPickerPersonnel()
    {
        pickerPersonnel = string.IsNullOrWhiteSpace(personPickerSearch)
            ? allPersonnel.ToList()
            : allPersonnel.Where(p => p.FullName.Contains(personPickerSearch, StringComparison.OrdinalIgnoreCase)).ToList();
    }

    private async Task AssignPersonFromPicker(Person person)
    {
        if (pickingForEvent is null) return;
        draggedPerson = person;
        await OnDropOnSlot(NormalizeToLocal(pickingForEvent.StartDateTime));
        pickingForEvent = null;
        personPickerSearch = "";
    }

    private void ClosePicker()
    {
        pickingForEvent = null;
        personPickerSearch = "";
    }

    private void OpenMessageModal() => showMessageModal = true;
    private void CloseMessageModal() => showMessageModal = false;

    private async Task ChangeStatus(Assignment a, string statusStr)
    {
        if (Enum.TryParse<AssignmentStatus>(statusStr, out var status))
        {
            await AssignmentSvc.UpdateStatusAsync(a.AssignmentId, status, currentUserId);
            a.Status = status;
        }
    }

    private static string GetRoleClass(Person p)
    {
        var roles = p.PersonRoles.Select(r => r.Role?.Name).ToList();
        bool isUsher = roles.Contains("Ujier");
        bool isSup = roles.Contains("Supervisor");
        return (isUsher, isSup) switch
        {
            (true, true) => "role-both",
            (false, true) => "role-supervisor",
            _ => "role-usher"
        };
    }

    private static string GetRoleLabel(Person p)
    {
        var roles = p.PersonRoles.Select(r => r.Role?.Name ?? "").Where(r => r != "User");
        return string.Join(" / ", roles);
    }

    private static string GetEventClass(Event ev)
    {
        var requiredTotal = ev.RequiredSupervisors + ev.RequiredUshers + ev.RequiredOther;
        var assignedTotal = ev.Assignments.Count(a =>
            a.Status == AssignmentStatus.Disponible ||
            a.Status == AssignmentStatus.Asignado ||
            a.Status == AssignmentStatus.Confirmado);

        var staffClass = assignedTotal >= requiredTotal ? "event-staffed" : "event-unstaffed";
        return ev.Active ? staffClass : $"{staffClass} event-inactive";
    }

    private static string GetStatusBadge(AssignmentStatus status) => status switch
    {
        AssignmentStatus.Confirmado => "bg-success",
        AssignmentStatus.Asignado => "bg-primary",
        AssignmentStatus.Disponible => "bg-info text-dark",
        AssignmentStatus.Ofrecido => "bg-warning text-dark",
        AssignmentStatus.Candidato => "bg-secondary",
        _ => "bg-secondary"
    };

    private static string FormatRequirements(Event ev)
    {
        var otherLabel = string.IsNullOrWhiteSpace(ev.RequiredOtherLabel) ? "Otro" : ev.RequiredOtherLabel;
        return $"Supervisores: {ev.RequiredSupervisors}, Ushers: {ev.RequiredUshers}, {otherLabel}: {ev.RequiredOther}";
    }

    private static DateTime NormalizeToLocal(DateTime value)
    {
        return value.Kind switch
        {
            DateTimeKind.Utc => value.ToLocalTime(),
            DateTimeKind.Local => value,
            _ => DateTime.SpecifyKind(value, DateTimeKind.Local)
        };
    }

    // ── Overlap layout ──────────────────────────────────────────────────────

    private Dictionary<int, (int Col, int Total)> _eventLayouts = new();

    private void ComputeAllLayouts()
    {
        _eventLayouts.Clear();
        for (int d = 0; d < 7; d++)
        {
            var day = weekStart.AddDays(d);
            var dayEvents = weekEvents
                .Where(e => NormalizeToLocal(e.StartDateTime).Date == day.Date)
                .OrderBy(e => NormalizeToLocal(e.StartDateTime))
                .ThenBy(e => NormalizeToLocal(e.EndDateTime))
                .ToList();

            if (dayEvents.Count == 0) continue;

            // Greedy column assignment: assign lowest free column to each event
            var assigned = new Dictionary<int, int>(); // eventId → column index

            foreach (var ev in dayEvents)
            {
                var start = NormalizeToLocal(ev.StartDateTime);
                var end   = NormalizeToLocal(ev.EndDateTime);

                var usedCols = dayEvents
                    .Where(o => assigned.ContainsKey(o.EventId) && EventsOverlap(start, end, o))
                    .Select(o => assigned[o.EventId])
                    .ToHashSet();

                int col = 0;
                while (usedCols.Contains(col)) col++;
                assigned[ev.EventId] = col;
            }

            // Total columns for each event = max col in its direct-overlap group + 1
            foreach (var ev in dayEvents)
            {
                var start = NormalizeToLocal(ev.StartDateTime);
                var end   = NormalizeToLocal(ev.EndDateTime);

                int total = dayEvents
                    .Where(o => assigned.ContainsKey(o.EventId) &&
                                (o.EventId == ev.EventId || EventsOverlap(start, end, o)))
                    .Max(o => assigned[o.EventId]) + 1;

                _eventLayouts[ev.EventId] = (assigned[ev.EventId], total);
            }
        }
    }

    private bool EventsOverlap(DateTime start, DateTime end, Event other)
    {
        var oStart = NormalizeToLocal(other.StartDateTime);
        var oEnd   = NormalizeToLocal(other.EndDateTime);
        return start < oEnd && end > oStart;
    }

    private string GetEventPositionStyle(Event ev)
    {
        if (!_eventLayouts.TryGetValue(ev.EventId, out var layout) || layout.Total <= 1)
            return "";

        var (col, total) = layout;
        var slotPct  = 100.0 / total;
        var leftPct  = col * slotPct;
        return $"left:calc({leftPct:F2}% + 2px);width:calc({slotPct:F2}% - 4px);right:auto;";
    }
}
