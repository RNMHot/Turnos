@page "/records"
@attribute [Authorize(Policy = "AppAccess", Roles = "Gerencia,Admin")]
@rendermode InteractiveServer
@inject AppDbContext Db
@inject AuthenticationStateProvider AuthState
@inject AuditService Audit

<PageTitle>Records — Turnos</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-journal-text me-2"></i>Records</h4>
    <button class="btn btn-primary btn-sm" @onclick="() => OpenForm(null)"><i class="bi bi-plus me-1"></i>Add Record</button>
</div>

<div class="d-flex gap-2 mb-3 flex-wrap">
    <input class="form-control form-control-sm" style="max-width:220px" placeholder="Search title…" @bind="search" @bind:event="oninput" @bind:after="Load" />
    <select class="form-select form-select-sm" style="max-width:160px" @bind="filterCategory" @bind:after="Load">
        <option value="">All categories</option>
        @foreach (var cat in categories)
        {
            <option value="@cat">@cat</option>
        }
    </select>
</div>

<div class="table-responsive">
    <table class="table table-hover table-sm align-middle">
        <thead class="table-light">
            <tr><th>Category</th><th>Title</th><th>Related</th><th>Updated</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var r in records)
            {
                <tr>
                    <td><span class="badge bg-secondary">@r.Category</span></td>
                    <td>
                        <strong>@r.Title</strong>
                        @if (!string.IsNullOrEmpty(r.Description))
                        {
                            <div class="text-muted small">@r.Description[..Math.Min(80, r.Description.Length)]…</div>
                        }
                    </td>
                    <td>@(r.RelatedEntityType != null ? $"{r.RelatedEntityType} #{r.RelatedEntityId}" : "—")</td>
                    <td>@r.UpdatedDate.ToString("MMM d, yyyy")</td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => OpenForm(r)"><i class="bi bi-pencil"></i></button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => Delete(r)"><i class="bi bi-trash"></i></button>
                    </td>
                </tr>
            }
            @if (!records.Any())
            {
                <tr><td colspan="5" class="text-muted text-center py-4">No records found.</td></tr>
            }
        </tbody>
    </table>
</div>

<!-- Inline form modal -->
@if (editing is not null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.4)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(editing.RecordId == 0 ? "New Record" : "Edit Record")</h5>
                    <button class="btn-close" @onclick="() => editing = null"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-2">
                        <label class="form-label">Category</label>
                        <input class="form-control" @bind="editing.Category" placeholder="e.g. Incident, Note, Contract" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Title *</label>
                        <input class="form-control" @bind="editing.Title" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" rows="4" @bind="editing.Description"></textarea>
                    </div>
                    <div class="row g-2">
                        <div class="col">
                            <label class="form-label">Related Entity Type</label>
                            <input class="form-control" @bind="editing.RelatedEntityType" placeholder="Person, Event…" />
                        </div>
                        <div class="col">
                            <label class="form-label">Related ID</label>
                            <input type="number" class="form-control" @bind="editing.RelatedEntityId" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => editing = null">Cancel</button>
                    <button class="btn btn-primary" @onclick="Save">Save</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Record> records = new();
    private List<string> categories = new();
    private string search = "";
    private string filterCategory = "";
    private Record? editing;
    private string userId = "";

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
        await Load();
    }

    private async Task Load()
    {
        var query = Db.Records.AsQueryable();
        if (!string.IsNullOrWhiteSpace(search))
            query = query.Where(r => r.Title.Contains(search));
        if (!string.IsNullOrWhiteSpace(filterCategory))
            query = query.Where(r => r.Category == filterCategory);

        records = await Microsoft.EntityFrameworkCore.EntityFrameworkQueryableExtensions.ToListAsync(query.OrderByDescending(r => r.UpdatedDate));
        categories = await Microsoft.EntityFrameworkCore.EntityFrameworkQueryableExtensions.ToListAsync(Db.Records.Select(r => r.Category).Distinct().OrderBy(c => c));
    }

    private void OpenForm(Record? record)
    {
        editing = record is null ? new Record { CreatedDate = DateTime.UtcNow, UpdatedDate = DateTime.UtcNow } : record;
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(editing!.Title)) return;
        editing.UpdatedDate = DateTime.UtcNow;

        if (editing.RecordId == 0)
        {
            editing.CreatedDate = DateTime.UtcNow;
            Db.Records.Add(editing);
            await Db.SaveChangesAsync();
            await Audit.LogAsync(userId, "Create", "Record", editing.RecordId, editing.Title);
        }
        else
        {
            Db.Records.Update(editing);
            await Db.SaveChangesAsync();
            await Audit.LogAsync(userId, "Update", "Record", editing.RecordId, editing.Title);
        }

        editing = null;
        await Load();
    }

    private async Task Delete(Record r)
    {
        Db.Records.Remove(r);
        await Db.SaveChangesAsync();
        await Audit.LogAsync(userId, "Delete", "Record", r.RecordId, r.Title);
        await Load();
    }
}
