@page "/account/login"
@layout Turnos.Components.Layout.EmptyLayout
@inject IAntiforgery Antiforgery
@inject IHttpContextAccessor HttpContextAccessor

@* SSR only — no @rendermode. Form posts to AccountController which handles cookies. *@

@{
    var tokens = Antiforgery.GetAndStoreTokens(HttpContextAccessor.HttpContext!);
    var error = HttpContextAccessor.HttpContext!.Request.Query["error"].ToString();
    var denied = HttpContextAccessor.HttpContext!.Request.Query["denied"].ToString();
    var returnUrl = HttpContextAccessor.HttpContext.Request.Query["returnUrl"].ToString();
}

<PageTitle>Login — Turnos</PageTitle>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<div class="d-flex justify-content-center align-items-center vh-100 bg-light">
    <div class="card shadow-sm" style="width:380px">
        <div class="card-body p-4">
            <h4 class="mb-1 fw-bold">
                <i class="bi bi-calendar-week text-primary me-2"></i>Turnos
            </h4>
            <p class="text-muted mb-4">Event Staffing &amp; Scheduling</p>

            @if (error == "1")
            {
                <div class="alert alert-danger py-2">Invalid email or password.</div>
            }
            @if (denied == "1")
            {
                <div class="alert alert-warning py-2">Tu usuario no tiene acceso activo a la aplicacion.</div>
            }

            <form method="post" action="/account/signin">
                <input type="hidden" name="@tokens.FormFieldName" value="@tokens.RequestToken" />
                <input type="hidden" name="returnUrl" value="@returnUrl" />

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input type="email" name="email" class="form-control" autocomplete="username" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <input type="password" name="password" class="form-control" autocomplete="current-password" required />
                </div>
                <div class="mb-3 form-check">
                    <input type="checkbox" name="rememberMe" value="true" class="form-check-input" id="rememberMe" />
                    <label class="form-check-label" for="rememberMe">Remember me</label>
                </div>
                <button type="submit" class="btn btn-primary w-100">Sign In</button>
            </form>
        </div>
    </div>
</div>
