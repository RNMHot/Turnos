@page "/locations"
@attribute [Authorize(Policy = "AppAccess", Roles = "Gerencia,Admin")]
@rendermode InteractiveServer
@inject LocationService LocationSvc
@inject AuthenticationStateProvider AuthState
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Localidades — Turnos</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <MudText Typo="Typo.h5">Localidades</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               Href="/locations/new" Size="Size.Small">Agregar Localidad</MudButton>
</div>

<MudTextField @bind-Value="_searchString" Placeholder="Buscar..."
              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
              Immediate="true" Clearable="true" Class="mb-3" Style="max-width:400px"
              Variant="Variant.Outlined" Margin="Margin.Dense" DebounceInterval="300"
              OnDebounceIntervalElapsed="OnSearchChanged" OnClearButtonClick="OnSearchCleared" />

<MudTable Items="@locations" Dense="true" Hover="true"
          T="Location" Elevation="2" Class="rounded" Style="font-size:0.85rem">
    <HeaderContent>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<Location, object>(x => x.Name)">
                Nombre
            </MudTableSortLabel>
        </MudTh>
        <MudTh>Dirección</MudTh>
        <MudTh>Coordenadas</MudTh>
        <MudTh>Estacionamiento</MudTh>
        <MudTh></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Nombre" Class="mud-text-bold">@context.Name</MudTd>
        <MudTd DataLabel="Dirección" Class="mud-text-secondary">@Truncate(context.Address, 60)</MudTd>
        <MudTd DataLabel="Coordenadas">
            @if (context.Latitude.HasValue && context.Longitude.HasValue)
            {
                <MudLink Href="@($"https://maps.google.com/?q={context.Latitude},{context.Longitude}")"
                         Target="_blank" Color="Color.Inherit" Class="mud-text-secondary">
                    <MudIcon Icon="@Icons.Material.Filled.PinDrop" Size="Size.Small" Class="mr-1" />
                    @context.Latitude.Value.ToString("F5"), @context.Longitude.Value.ToString("F5")
                </MudLink>
            }
            else
            {
                <span class="mud-text-secondary">—</span>
            }
        </MudTd>
        <MudTd DataLabel="Estacionamiento" Class="mud-text-secondary">@Truncate(context.ParkingInfo, 50)</MudTd>
        <MudTd DataLabel="">
            <div style="display:flex; align-items:center; justify-content:flex-end">
                <MudTooltip Text="Editar localidad">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary"
                                   Size="Size.Small" Href="@($"/locations/{context.LocationId}")" />
                </MudTooltip>
                <MudTooltip Text="Eliminar localidad">
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                   Size="Size.Small" OnClick="() => ConfirmDelete(context)" />
                </MudTooltip>
            </div>
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText Typo="Typo.body1" Class="py-4 mud-text-secondary" Style="display:block;text-align:center">
            No se encontraron localidades.
        </MudText>
    </NoRecordsContent>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[] { 25, 50, 100 }" />
    </PagerContent>
</MudTable>

@code {
    private List<Location> locations = new();
    private string _searchString = "";
    private string userId = "";

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
        await Load();
    }

    private async Task Load() => locations = await LocationSvc.GetAllAsync(_searchString);

    private async Task OnSearchChanged() => await Load();

    private async Task OnSearchCleared()
    {
        _searchString = "";
        await Load();
    }

    private async Task ConfirmDelete(Location loc)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Eliminar Localidad",
            $"¿Desea eliminar la localidad {loc.Name}?",
            yesText: "Sí, eliminar",
            cancelText: "No");

        if (confirmed == true)
        {
            var ok = await LocationSvc.DeleteAsync(loc.LocationId, userId);
            if (!ok)
                Snackbar.Add($"\"{loc.Name}\" está asignada a uno o más eventos y no se puede eliminar. Primero elimínela de esos eventos.", Severity.Warning);
            else
            {
                Snackbar.Add("Localidad eliminada", Severity.Info);
                await Load();
            }
        }
    }

    private static string? Truncate(string? value, int max) =>
        value is null ? null : value.Length <= max ? value : value[..max] + "…";
}
