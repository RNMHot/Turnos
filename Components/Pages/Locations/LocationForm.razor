@page "/locations/new"
@page "/locations/{Id:int}"
@attribute [Authorize]
@rendermode InteractiveServer
@inject LocationService LocationSvc
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

<PageTitle>@(Id == 0 ? "New Location" : "Edit Location") — Turnos</PageTitle>

<div class="d-flex align-items-center gap-2 mb-3">
    <a href="/locations" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h4 class="mb-0">@(Id == 0 ? "New Location" : "Edit Location")</h4>
</div>

<div class="card shadow-sm" style="max-width:680px">
    <div class="card-body">
        <EditForm Model="loc" OnValidSubmit="Save">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" />

            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label">Location Name *</label>
                    <InputText @bind-Value="loc.Name" class="form-control" placeholder="e.g. Convention Center Hall A" />
                    <ValidationMessage For="() => loc.Name" />
                </div>

                <div class="col-12">
                    <label class="form-label">Address</label>
                    <InputTextArea @bind-Value="loc.Address" class="form-control" rows="2"
                                   placeholder="Street, city, state, ZIP…" />
                </div>

                <div class="col-md-5">
                    <label class="form-label">Latitude</label>
                    <InputNumber @bind-Value="loc.Latitude" class="form-control"
                                 placeholder="e.g. 25.774772" />
                    <div class="form-text">Decimal degrees (positive = North)</div>
                </div>
                <div class="col-md-5">
                    <label class="form-label">Longitude</label>
                    <InputNumber @bind-Value="loc.Longitude" class="form-control"
                                 placeholder="e.g. -80.185942" />
                    <div class="form-text">Decimal degrees (negative = West)</div>
                </div>
                <div class="col-md-2 d-flex align-items-end pb-1">
                    @if (loc.Latitude.HasValue && loc.Longitude.HasValue)
                    {
                        <a href="https://maps.google.com/?q=@loc.Latitude,@loc.Longitude"
                           target="_blank" rel="noopener"
                           class="btn btn-outline-secondary btn-sm w-100"
                           title="Preview on Google Maps">
                            <i class="bi bi-map"></i> Map
                        </a>
                    }
                </div>

                <div class="col-12">
                    <label class="form-label">Parking Information</label>
                    <InputTextArea @bind-Value="loc.ParkingInfo" class="form-control" rows="3"
                                   placeholder="Describe parking options, costs, entrances…" />
                </div>
            </div>

            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-primary" disabled="@saving">
                    @(saving ? "Saving…" : "Save")
                </button>
                <a href="/locations" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter] public int Id { get; set; }

    private Location loc = new();
    private bool saving;
    private string userId = "";

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";

        if (Id != 0)
        {
            var existing = await LocationSvc.GetByIdAsync(Id);
            if (existing is not null) loc = existing;
        }
    }

    private async Task Save()
    {
        saving = true;
        if (Id == 0) await LocationSvc.CreateAsync(loc, userId);
        else await LocationSvc.UpdateAsync(loc, userId);
        Nav.NavigateTo("/locations");
    }
}
