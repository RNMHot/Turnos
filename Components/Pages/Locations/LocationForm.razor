@page "/locations/new"
@page "/locations/{Id:int}"
@attribute [Authorize(Policy = "AppAccess", Roles = "Gerencia,Admin")]
@rendermode InteractiveServer
@inject LocationService LocationSvc
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>@(Id == 0 ? "Nueva Localidad" : "Editar Localidad") — Turnos</PageTitle>

<div class="d-flex align-items-center gap-2 mb-3">
    <a href="/locations" class="btn btn-outline-secondary btn-sm" title="Regresar"><i class="bi bi-arrow-left"></i></a>
    <h4 class="mb-0">@(Id == 0 ? "Nueva Localidad" : "Editar Localidad")</h4>
</div>

<EditForm Model="loc" OnValidSubmit="Save" id="location-form">
    <DataAnnotationsValidator />

    <ValidationSummary class="text-danger mb-3" />

    <div class="d-flex gap-2 justify-content-between">
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary" disabled="@saving">
                @(saving ? "Guardando…" : "Guardar")
            </button>
            <a href="/locations" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </div>
    <br />

    <div class="card shadow-sm" style="max-width:680px">
        <div class="card-header fw-semibold">Datos de la Localidad</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label">Nombre *</label>
                    <InputText @bind-Value="loc.Name" class="form-control" placeholder="e.g. Salón A del Centro de Convenciones" />
                    <ValidationMessage For="() => loc.Name" />
                </div>

                <div class="col-12">
                    <label class="form-label">Dirección</label>
                    <InputTextArea @bind-Value="loc.Address" class="form-control" rows="2"
                                   placeholder="Calle, ciudad, estado, código postal…" />
                </div>

                <div class="col-md-5">
                    <label class="form-label">Latitud</label>
                    <InputNumber @bind-Value="loc.Latitude" class="form-control"
                                 placeholder="e.g. 25.774772" />
                </div>
                <div class="col-md-5">
                    <label class="form-label">Longitud</label>
                    <InputNumber @bind-Value="loc.Longitude" class="form-control"
                                 placeholder="e.g. -80.185942" />
                </div>
                <div class="col-md-2 d-flex align-items-end pb-1">
                    @if (loc.Latitude.HasValue && loc.Longitude.HasValue)
                    {
                        <a href="https://maps.google.com/?q=@loc.Latitude,@loc.Longitude"
                           target="_blank" rel="noopener"
                           class="btn btn-outline-secondary btn-sm w-100"
                           title="Ver en Google Maps">
                            <i class="bi bi-map"></i> Mapa
                        </a>
                    }
                </div>

                <div class="col-12">
                    <label class="form-label">Información de Estacionamiento</label>
                    <InputTextArea @bind-Value="loc.ParkingInfo" class="form-control" rows="3"
                                   placeholder="Describe las opciones de estacionamiento, costos, entradas…" />
                </div>
            </div>
        </div>
    </div>
</EditForm>

@if (Id != 0)
{
    <div class="card shadow-sm mt-3" style="max-width:680px">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h6 class="mb-0"><i class="bi bi-pin-map me-2"></i>Posiciones</h6>
            <span class="badge bg-secondary">@positions.Count</span>
        </div>
        <div class="card-body">
            @if (positions.Count == 0)
            {
                <p class="text-muted small mb-3">No hay posiciones definidas para esta localidad.</p>
            }
            else
            {
                <ul class="list-group mb-3">
                    @foreach (var pos in positions)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center py-2">
                            <span>@pos.Name</span>
                            <button type="button" class="btn btn-outline-danger btn-sm"
                                    @onclick="() => DeletePosition(pos.LocationPositionId)"
                                    title="Eliminar posición">
                                <i class="bi bi-trash"></i>
                            </button>
                        </li>
                    }
                </ul>
            }

            <div class="d-flex gap-2">
                <input type="text" class="form-control form-control-sm"
                       placeholder="Nombre de la posición (ej. Puerta Principal, Balcón Derecho…)"
                       @bind="newPositionName" @bind:event="oninput"
                       @onkeydown="OnPositionKeyDown" />
                <button type="button" class="btn btn-outline-primary btn-sm text-nowrap"
                        disabled="@(string.IsNullOrWhiteSpace(newPositionName))"
                        @onclick="AddPosition">
                    <i class="bi bi-plus"></i> Agregar
                </button>
            </div>
        </div>
    </div>
}
else
{
    <div class="text-muted small mt-2" style="max-width:680px">
        <i class="bi bi-info-circle me-1"></i>Guarda la localidad primero para poder agregar posiciones.
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private Location loc = new();
    private List<LocationPosition> positions = new();
    private string newPositionName = "";
    private bool saving;
    private string userId = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("preventEnterSubmit", "location-form");
    }

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";

        if (Id != 0)
        {
            var existing = await LocationSvc.GetByIdAsync(Id);
            if (existing is not null) loc = existing;
            positions = await LocationSvc.GetPositionsAsync(Id);
        }
    }

    private async Task Save()
    {
        saving = true;
        if (Id == 0)
        {
            var created = await LocationSvc.CreateAsync(loc, userId);
            Nav.NavigateTo($"/locations/{created.LocationId}");
        }
        else
        {
            await LocationSvc.UpdateAsync(loc, userId);
            Nav.NavigateTo("/locations");
        }
    }

    private async Task AddPosition()
    {
        if (string.IsNullOrWhiteSpace(newPositionName)) return;
        var pos = await LocationSvc.AddPositionAsync(Id, newPositionName, userId);
        positions.Add(pos);
        newPositionName = "";
    }

    private async Task OnPositionKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await AddPosition();
    }

    private async Task DeletePosition(int positionId)
    {
        await LocationSvc.DeletePositionAsync(positionId, userId);
        positions.RemoveAll(p => p.LocationPositionId == positionId);
    }
}
