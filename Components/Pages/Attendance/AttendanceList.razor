@page "/attendance"
@attribute [Authorize(Policy = "AppAccess", Roles = "Gerencia,Admin")]
@rendermode InteractiveServer
@inject AttendanceService AttendanceSvc
@inject PersonService PersonSvc
@inject ExcelExportService Excel
@inject AuthenticationStateProvider AuthState
@inject IJSRuntime JS
@inject AppSettingsState SettingsState
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Asistencia - Turnos</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div class="d-flex align-items-center gap-3 flex-wrap">
        <MudText Typo="Typo.h5">Asistencia</MudText>
        @if (periodMode == "week" || periodMode == "biweekly")
        {
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                <MudIcon Icon="@Icons.Material.Filled.DateRange" Size="Size.Small" Class="mr-1" />
                Periodo: <strong>@PeriodRangeLabel</strong>
            </MudText>
        }
    </div>
    <div class="d-flex gap-2">
        <MudButton Variant="Variant.Outlined" Color="Color.Success"
                   StartIcon="@Icons.Material.Filled.FileDownload"
                   OnClick="ExportExcel" Size="Size.Small">Exportar</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   Href="/attendance/new" Size="Size.Small">Agregar Asistencia</MudButton>
    </div>
</div>

<MudPaper Elevation="2" Class="pa-3 mb-3 rounded">
    <div class="d-flex gap-2 flex-wrap align-items-start">
        <MudSelect T="int?" @bind-Value="filterPersonId" @bind-Value:after="Load" Label="Persona"
                   Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width:220px">
            @foreach (var p in persons)
            {
                <MudSelectItem T="int?" Value="@((int?)p.PersonId)">@p.FullName</MudSelectItem>
            }
        </MudSelect>
        <MudSelect T="string" @bind-Value="periodMode" @bind-Value:after="Load" Label="Periodo"
                   Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width:150px">
            <MudSelectItem T="string" Value="@("week")">Semana</MudSelectItem>
            <MudSelectItem T="string" Value="@("biweekly")">Bisemana</MudSelectItem>
            <MudSelectItem T="string" Value="@("range")">Rango</MudSelectItem>
        </MudSelect>

        @if (periodMode == "week")
        {
            <MudDatePicker Date="@weekStartDate" DateChanged="OnWeekStartDateChanged"
                           Label="Semana (lunes)" Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width:190px" />
        }
        else if (periodMode == "biweekly")
        {
            <MudDatePicker Date="@biweeklyStartDate" DateChanged="OnBiweeklyStartDateChanged"
                           Label="Periodo bisemanal (fecha de referencia)" Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width:220px" />
        }
        else
        {
            <MudDatePicker Date="@rangeStartDate" DateChanged="OnRangeStartDateChanged"
                           Label="Desde" Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width:160px" />
            <MudDatePicker Date="@rangeEndDate" DateChanged="OnRangeEndDateChanged"
                           Label="Hasta" Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width:160px" />
        }

        <MudSelect T="string" @bind-Value="viewMode" Label="Vista"
                   Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width:190px">
            <MudSelectItem T="string" Value="@("detail")">Detallada</MudSelectItem>
            <MudSelectItem T="string" Value="@("summary")">Resumen por persona</MudSelectItem>
        </MudSelect>
    </div>
</MudPaper>

<MudPaper Elevation="0" Class="pa-3 mb-3 rounded" Style="max-width:280px; background-color:var(--mud-palette-background-gray)">
    <MudText Typo="Typo.body2" Class="mud-text-secondary">Total del periodo</MudText>
    <MudText Typo="Typo.h5">@FormatHours(totalPeriodHours)</MudText>
</MudPaper>

<MudTextField @bind-Value="_searchString" Placeholder="Buscar persona o evento..."
              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
              Immediate="true" Clearable="true" Class="mb-3" Style="max-width:400px"
              Variant="Variant.Outlined" Margin="Margin.Dense" />

@if (viewMode == "summary")
{
    <MudTable Items="@personTotals" Dense="true" Hover="true" Filter="@FilterSummaryFunc"
              T="PersonTotal" Elevation="2" Class="rounded" Style="font-size:0.85rem">
        <HeaderContent>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<PersonTotal, object>(x => x.PersonName)">
                    Persona
                </MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<PersonTotal, object>(x => x.Hours)">
                    Horas en el periodo
                </MudTableSortLabel>
            </MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Persona">@context.PersonName</MudTd>
            <MudTd DataLabel="Horas en el periodo" Class="mud-text-bold">@FormatHours(context.Hours)</MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Typo="Typo.body1" Class="py-4 mud-text-secondary" Style="display:block;text-align:center">
                No hay asistencia registrada en este periodo.
            </MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 25, 50, 100 }" />
        </PagerContent>
    </MudTable>
}
else
{
    <MudTable Items="@attendance" Dense="true" Hover="true" Filter="@FilterDetailFunc"
              T="Attendance" Elevation="2" Class="rounded" Style="font-size:0.85rem">
        <HeaderContent>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<Attendance, object>(x => x.Person.FullName)">
                    Persona
                </MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<Attendance, object>(x => x.Event.EventName)">
                    Evento
                </MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<Attendance, object>(x => x.CheckInDateTime)">
                    Entrada
                </MudTableSortLabel>
            </MudTh>
            <MudTh>Salida</MudTh>
            <MudTh>Descansos</MudTh>
            <MudTh>Horas por turno</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Persona">@context.Person.FullName</MudTd>
            <MudTd DataLabel="Evento">
                <div>@context.Event.EventName</div>
                <div class="mud-text-secondary" style="font-size:0.8rem">@context.Event.Company?.Name</div>
            </MudTd>
            <MudTd DataLabel="Entrada">@SettingsState.ToDisplay(context.CheckInDateTime).ToString("yyyy-MM-dd HH:mm")</MudTd>
            <MudTd DataLabel="Salida">@(context.CheckOutDateTime.HasValue ? SettingsState.ToDisplay(context.CheckOutDateTime.Value).ToString("yyyy-MM-dd HH:mm") : "Abierta")</MudTd>
            <MudTd DataLabel="Descansos">@Math.Round(GetBreakMinutes(context), 0) min (@context.Breaks.Count)</MudTd>
            <MudTd DataLabel="Horas por turno" Class="mud-text-bold">@FormatHours(GetWorkedHours(context))</MudTd>
            <MudTd DataLabel="">
                <div style="display:flex; align-items:center; justify-content:flex-end">
                    <MudTooltip Text="Editar">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary"
                                       Size="Size.Small" Href="@($"/attendance/{context.AttendanceId}")" />
                    </MudTooltip>
                    <MudTooltip Text="Eliminar">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                       Size="Size.Small" OnClick="() => ConfirmDelete(context)" />
                    </MudTooltip>
                </div>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Typo="Typo.body1" Class="py-4 mud-text-secondary" Style="display:block;text-align:center">
                No hay asistencia registrada en este periodo.
            </MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 25, 50, 100 }" />
        </PagerContent>
    </MudTable>
}

@code {
    private List<Attendance> attendance = new();
    private List<Person> persons = new();
    private int? filterPersonId;
    private string periodMode = "week";
    private string viewMode = "detail";
    private DateTime weekStartDate;
    private DateTime biweeklyStartDate;
    private DateTime rangeStartDate;
    private DateTime rangeEndDate;
    private string userId = "";
    private string _searchString = "";
    private decimal totalPeriodHours;
    private List<PersonTotal> personTotals = new();
    private int _loadVersion = 0;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
        weekStartDate = GetMonday(SettingsState.Today);
        biweeklyStartDate = SettingsState.GetBiweeklyPeriodStart(SettingsState.Today);
        rangeStartDate = SettingsState.Today.AddDays(-7);
        rangeEndDate = SettingsState.Today;
        persons = await PersonSvc.GetAllAsync(active: true);
        await Load();
    }

    private async Task Load()
    {
        var version = ++_loadVersion;
        if (periodMode == "week")
            weekStartDate = GetMonday(weekStartDate);
        else if (periodMode == "biweekly")
            biweeklyStartDate = SettingsState.GetBiweeklyPeriodStart(biweeklyStartDate);
        var (fromUtc, toUtc) = GetCurrentRangeUtc();
        var result = await AttendanceSvc.GetByRangeAsync(fromUtc, toUtc, filterPersonId);
        if (version != _loadVersion) return;
        attendance = result;
        RecalculateTotals();
    }

    private async Task OnWeekStartDateChanged(DateTime? date)
    {
        if (date.HasValue) weekStartDate = date.Value;
        await Load();
    }

    private async Task OnBiweeklyStartDateChanged(DateTime? date)
    {
        if (date.HasValue) biweeklyStartDate = date.Value;
        await Load();
    }

    private async Task OnRangeStartDateChanged(DateTime? date)
    {
        if (date.HasValue) rangeStartDate = date.Value;
        await Load();
    }

    private async Task OnRangeEndDateChanged(DateTime? date)
    {
        if (date.HasValue) rangeEndDate = date.Value;
        await Load();
    }

    private (DateTime FromUtc, DateTime ToUtc) GetCurrentRangeUtc()
    {
        var (fromLocal, toLocal) = GetCurrentRangeLocal();
        return (ToUtc(fromLocal), ToUtc(toLocal));
    }

    private (DateTime FromLocal, DateTime ToLocal) GetCurrentRangeLocal()
    {
        DateTime fromLocal;
        DateTime toLocal;

        if (periodMode == "week")
        {
            var monday = GetMonday(weekStartDate);
            fromLocal = monday;
            toLocal = monday.AddDays(7);
        }
        else if (periodMode == "biweekly")
        {
            var periodStart = SettingsState.GetBiweeklyPeriodStart(biweeklyStartDate);
            fromLocal = periodStart;
            toLocal = periodStart.AddDays(14);
        }
        else
        {
            if (rangeEndDate < rangeStartDate)
                rangeEndDate = rangeStartDate;

            fromLocal = rangeStartDate.Date;
            toLocal = rangeEndDate.Date.AddDays(1);
        }

        return (fromLocal, toLocal);
    }

    private string PeriodRangeLabel
    {
        get
        {
            var (fromLocal, toLocal) = GetCurrentRangeLocal();
            return $"{fromLocal:MM/dd/yyyy} - {toLocal.AddDays(-1):MM/dd/yyyy}";
        }
    }

    private void RecalculateTotals()
    {
        totalPeriodHours = attendance.Sum(a => (decimal)GetWorkedHours(a));
        personTotals = attendance
            .GroupBy(a => a.Person.FullName)
            .Select(g => new PersonTotal(g.Key, g.Sum(GetWorkedHours)))
            .OrderBy(x => x.PersonName)
            .ToList();
    }

    private double GetWorkedHours(Attendance item)
    {
        var end = item.CheckOutDateTime ?? DateTime.UtcNow;
        var totalMinutes = (end - item.CheckInDateTime).TotalMinutes;
        var breakMinutes = GetBreakMinutes(item);
        return Math.Max(0, (totalMinutes - breakMinutes) / 60.0);
    }

    private static double GetBreakMinutes(Attendance item)
    {
        return item.Breaks
            .Sum(b => ((b.BreakEndDateTime ?? DateTime.UtcNow) - b.BreakStartDateTime).TotalMinutes);
    }

    private bool FilterDetailFunc(Attendance a) =>
        string.IsNullOrWhiteSpace(_searchString)
        || (a.Person?.FullName?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false)
        || (a.Event?.EventName?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false);

    private bool FilterSummaryFunc(PersonTotal p) =>
        string.IsNullOrWhiteSpace(_searchString)
        || p.PersonName.Contains(_searchString, StringComparison.OrdinalIgnoreCase);

    private async Task ConfirmDelete(Attendance item)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Eliminar Asistencia",
            $"¿Desea eliminar el registro de asistencia de {item.Person.FullName} — {item.Event.EventName}?",
            yesText: "Sí, eliminar",
            cancelText: "No");

        if (confirmed == true)
        {
            await AttendanceSvc.DeleteAsync(item.AttendanceId, userId);
            Snackbar.Add("Registro eliminado", Severity.Info);
            await Load();
        }
    }

    private async Task ExportExcel()
    {
        var bytes = Excel.ExportAttendance(attendance);
        await JS.InvokeVoidAsync("downloadFile", "attendance.xlsx", Convert.ToBase64String(bytes));
    }

    private DateTime ToUtc(DateTime local) => SettingsState.ToUtc(local);

    private static string FormatHours(decimal hours) => $"{hours:0.##} h ({FormatHm(hours)})";

    private static string FormatHours(double hours) => $"{hours:0.##} h ({FormatHm((decimal)hours)})";

    private static string FormatHm(decimal hours)
    {
        var totalMinutes = (int)Math.Round(hours * 60, MidpointRounding.AwayFromZero);
        var h = totalMinutes / 60;
        var m = totalMinutes % 60;
        return $"{h:00}:{m:00}";
    }

    private static DateTime GetMonday(DateTime date)
    {
        int diff = (7 + (date.DayOfWeek - DayOfWeek.Monday)) % 7;
        return date.AddDays(-diff).Date;
    }

    private record PersonTotal(string PersonName, double Hours);
}
