@page "/personnel/new"
@page "/personnel/{Id:int}"
@attribute [Authorize]
@rendermode InteractiveServer
@inject PersonService PersonSvc
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

<PageTitle>@(Id == 0 ? "Nueva Persona" : "Editar Persona") — Turnos</PageTitle>

<div class="d-flex align-items-center gap-2 mb-3">
    <a href="/personnel" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h4 class="mb-0">@(Id == 0 ? "Nueva Persona" : "Editar Persona")</h4>
</div>

@if (loading)
{
    <p class="text-muted">Cargando…</p>
}
else
{
    <EditForm Model="person" OnValidSubmit="Save" style="max-width:600px">
        <DataAnnotationsValidator />

        @if (!string.IsNullOrEmpty(saveError))
        {
            <div class="alert alert-danger mb-3">@saveError</div>
        }
        @if (!string.IsNullOrEmpty(saveSuccess))
        {
            <div class="alert alert-success mb-3">@saveSuccess</div>
        }

        <ValidationSummary class="text-danger mb-3" />

        @* Card 1: Datos de Persona *@
        <div class="card shadow-sm mb-3">
            <div class="card-header fw-semibold">Datos Generales</div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Nombre completo *</label>
                    <InputText @bind-Value="person.FullName" class="form-control" />
                    <ValidationMessage For="() => person.FullName" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Número de teléfono *</label>
                    <InputText @bind-Value="person.PhoneNumber" class="form-control" placeholder="+1 555 000 0000" />
                    <ValidationMessage For="() => person.PhoneNumber" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <InputText @bind-Value="person.Email" class="form-control" type="email" />
                </div>
                <div class="mb-0">
                    <label class="form-label">Notas</label>
                    <InputTextArea @bind-Value="person.Notes" class="form-control" rows="3" />
                </div>
            </div>
        </div>

        @* Card 2: Roles y Acceso *@
        <div class="card shadow-sm mb-3">
            <div class="card-header fw-semibold">Roles y Acceso</div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Roles operativos</label>
                    <div class="form-text mb-2">Estos roles son de trabajo (evento), no de acceso a la aplicación.</div>
                    <div class="d-flex gap-3 flex-wrap">
                        @foreach (var role in allRoles)
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="role_@role.RoleId"
                                       checked="@selectedRoleIds.Contains(role.RoleId)"
                                       @onchange="e => ToggleRole(role.RoleId, (bool)e.Value!)" />
                                <label class="form-check-label" for="role_@role.RoleId">@role.Name</label>
                            </div>
                        }
                    </div>
                </div>
                <div class="mb-3 form-check">
                    <InputCheckbox @bind-Value="person.Active" class="form-check-input" id="active" />
                    <label class="form-check-label" for="active">Activo</label>
                </div>
                <div class="mb-2 form-check">
                    <InputCheckbox @bind-Value="person.CheckInOnly" class="form-check-input" id="checkInOnly" />
                    <label class="form-check-label" for="checkInOnly">Solo acceso a Ponchador (/attendance/checkin)</label>
                </div>
                <div class="form-text mb-0">
                    Si está activado, al iniciar sesión se redirige directo a Ponchador y no puede navegar a otras páginas.
                    Personal activo obtiene perfil User. Admin se asigna únicamente al usuario administrador.
                </div>
            </div>
        </div>

        @* Card 3: Contraseña — only when editing *@
        @if (Id != 0)
        {
            <div class="card shadow-sm mb-3">
                <div class="card-header fw-semibold">Contraseña</div>
                <div class="card-body">
                    <div class="mb-3 form-check">
                        <InputCheckbox @bind-Value="person.MustChangePassword" class="form-check-input" id="mustChangePwd" />
                        <label class="form-check-label" for="mustChangePwd">Debe cambiar contraseña al próximo inicio de sesión</label>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Nueva contraseña <span class="text-muted">(dejar vacío para no cambiar)</span></label>
                        <input type="password" class="form-control" @bind="newPassword" autocomplete="new-password" />
                    </div>
                    <div class="mb-0">
                        <label class="form-label">Confirmar nueva contraseña</label>
                        <input type="password" class="form-control" @bind="confirmPassword" autocomplete="new-password" />
                    </div>
                </div>
            </div>
        }

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary" disabled="@saving">
                @(saving ? "Guardando…" : "Guardar")
            </button>
            <a href="/personnel" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </EditForm>
}

@code {
    [Parameter] public int Id { get; set; }

    private Person person = new() { Active = true };
    private List<Role> allRoles = new();
    private List<int> selectedRoleIds = new();
    private bool loading = true;
    private bool saving;
    private string? saveError;
    private string? saveSuccess;
    private string userId = "";
    private string newPassword = "";
    private string confirmPassword = "";

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
        allRoles = await PersonSvc.GetRolesAsync();

        if (Id != 0)
        {
            var existing = await PersonSvc.GetByIdAsync(Id);
            if (existing is not null)
            {
                person = existing;
                selectedRoleIds = existing.PersonRoles.Select(pr => pr.RoleId).ToList();
            }
        }
        loading = false;
    }

    private void ToggleRole(int roleId, bool selected)
    {
        if (selected) { if (!selectedRoleIds.Contains(roleId)) selectedRoleIds.Add(roleId); }
        else selectedRoleIds.Remove(roleId);
    }

    private async Task Save()
    {
        saving = true;
        saveError = null;
        saveSuccess = null;
        try
        {
            if (!string.IsNullOrEmpty(newPassword) && newPassword != confirmPassword)
            {
                saveError = "Las contraseñas no coinciden.";
                saving = false;
                return;
            }

            if (Id == 0)
                await PersonSvc.CreateAsync(person, selectedRoleIds, userId);
            else
                await PersonSvc.UpdateAsync(person, selectedRoleIds, userId);

            if (!string.IsNullOrEmpty(newPassword))
            {
                var (success, error) = await PersonSvc.SetPasswordAsync(Id, newPassword, userId);
                if (!success)
                {
                    saveError = $"Persona guardada, pero error al establecer contraseña: {error}";
                    saving = false;
                    return;
                }
                newPassword = "";
                confirmPassword = "";
                saveSuccess = "Cambios guardados correctamente.";
                saving = false;
                return;
            }

            Nav.NavigateTo("/personnel");
        }
        catch (Exception ex)
        {
            saveError = ex.Message;
            saving = false;
        }
    }
}
