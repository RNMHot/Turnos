@page "/my-availability"
@attribute [Authorize(Policy = "AppAccess")]
@rendermode InteractiveServer
@inject PersonService PersonSvc
@inject AvailabilityService AvailSvc
@inject AuthenticationStateProvider AuthState

<PageTitle>Mi Disponibilidad — Turnos</PageTitle>

<div class="d-flex align-items-center gap-2 mb-3">
    <h4 class="mb-0">Mi No-Disponibilidad@(person is not null ? $": {person.FullName}" : "")</h4>
</div>

@if (!string.IsNullOrWhiteSpace(statusMsg))
{
    <div class="alert alert-danger py-2">@statusMsg</div>
}
else if (person is null)
{
    <p class="text-muted">Cargando…</p>
}
else
{
    <div class="row">
        <div class="col-md-5">
            <div class="card shadow-sm mb-3">
                <div class="card-header fw-bold">Registrar No-Disponibilidad</div>
                <div class="card-body">
                    <div class="mb-2">
                        <label class="form-label">Tipo</label>
                        <select class="form-select" @bind="newAvailType">
                            <option value="@AvailabilityType.Recurrente">Recurrente (semanal)</option>
                            <option value="@AvailabilityType.FechaEspecifica">Fecha específica</option>
                        </select>
                    </div>
                    @if (newAvailType == AvailabilityType.Recurrente)
                    {
                        <div class="mb-2">
                            <label class="form-label">Días de la semana</label>
                            <div class="d-flex gap-2 flex-wrap">
                                @foreach (var (key, label) in DayLabels)
                                {
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="day_@key"
                                               checked="@selectedDays.Contains(key)"
                                               @onchange="e => ToggleDay(key, (bool)e.Value!)" />
                                        <label class="form-check-label" for="day_@key">@label[..3]</label>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="mb-2">
                            <label class="form-label">Fecha</label>
                            <input type="date" class="form-control" @bind="specificDate" />
                        </div>
                    }
                    <div class="row g-2 mb-2">
                        <div class="col">
                            <label class="form-label">Hora de inicio</label>
                            <input type="time" class="form-control" @bind="startTime" />
                        </div>
                        <div class="col">
                            <label class="form-label">Hora de fin</label>
                            <input type="time" class="form-control" @bind="endTime" />
                        </div>
                    </div>
                    <button class="btn btn-primary btn-sm" @onclick="AddAvailability">
                        <i class="bi bi-plus me-1"></i>Agregar
                    </button>
                </div>
            </div>
        </div>
        <div class="col-md-7">
            <div class="card shadow-sm">
                <div class="card-header fw-bold">Periodos no disponible</div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr><th>Tipo</th><th>Día / Fecha</th><th>Hora</th><th></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var a in availabilities)
                            {
                                <tr>
                                    <td>@a.AvailabilityType</td>
                                    <td>
                                        @if (a.AvailabilityType == AvailabilityType.Recurrente)
                                            @(string.Join(", ", (a.DaysOfWeek?.Split(',', StringSplitOptions.RemoveEmptyEntries) ?? Array.Empty<string>()).Select(d => DayLabels.GetValueOrDefault(d, d))))
                                        else
                                            @(a.SpecificDate?.ToString("MMM d, yyyy") ?? "—")
                                    </td>
                                    <td>@DateTime.Today.Add(a.StartTime).ToString("hh:mm tt") – @DateTime.Today.Add(a.EndTime).ToString("hh:mm tt")</td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAvailability(a.AvailabilityId)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                            @if (!availabilities.Any())
                            {
                                <tr><td colspan="4" class="text-muted text-center py-3">Sin restricciones de disponibilidad.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private int? currentPersonId;
    private Person? person;
    private string? statusMsg;
    private List<Availability> availabilities = new();
    private AvailabilityType newAvailType = AvailabilityType.Recurrente;
    private List<string> selectedDays = new();
    private DateOnly specificDate = DateOnly.FromDateTime(DateTime.Today);
    private TimeOnly startTime = new TimeOnly(8, 0);
    private TimeOnly endTime = new TimeOnly(20, 0);

    private static readonly Dictionary<string, string> DayLabels = new()
    {
        { "Monday",    "Lunes" },
        { "Tuesday",   "Martes" },
        { "Wednesday", "Miércoles" },
        { "Thursday",  "Jueves" },
        { "Friday",    "Viernes" },
        { "Saturday",  "Sábado" },
        { "Sunday",    "Domingo" },
    };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var personClaim = authState.User.FindFirst(TurnosClaimTypes.PersonId)?.Value;
        if (!int.TryParse(personClaim, out var personId))
        {
            statusMsg = "Tu usuario no esta confirmado como ujier.";
            return;
        }

        currentPersonId = personId;
        person = await PersonSvc.GetByIdAsync(personId);
        await LoadAvailabilities();
    }

    private async Task LoadAvailabilities()
    {
        if (!currentPersonId.HasValue) return;
        availabilities = (await AvailSvc.GetForPersonAsync(currentPersonId.Value))
            .Where(a => !a.Deleted)
            .ToList();
    }

    private void ToggleDay(string day, bool selected)
    {
        if (selected) { if (!selectedDays.Contains(day)) selectedDays.Add(day); }
        else selectedDays.Remove(day);
    }

    private async Task AddAvailability()
    {
        if (!currentPersonId.HasValue) return;

        var avail = new Availability
        {
            PersonId = currentPersonId.Value,
            AvailabilityType = newAvailType,
            StartTime = startTime.ToTimeSpan(),
            EndTime = endTime.ToTimeSpan(),
            IsUnavailable = true
        };

        if (newAvailType == AvailabilityType.Recurrente)
            avail.DaysOfWeek = string.Join(",", selectedDays);
        else
            avail.SpecificDate = specificDate.ToDateTime(TimeOnly.MinValue);

        await AvailSvc.CreateAsync(avail);
        selectedDays.Clear();
        await LoadAvailabilities();
    }

    private async Task DeleteAvailability(int id)
    {
        await AvailSvc.DeleteAsync(id);
        await LoadAvailabilities();
    }
}
