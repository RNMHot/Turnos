@page "/personnel"
@attribute [Authorize(Policy = "AppAccess", Roles = "Gerencia,Admin")]
@rendermode InteractiveServer
@inject PersonService PersonSvc
@inject ExcelExportService Excel
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Personal — Turnos</PageTitle>

<div class="d-flex flex-column" style="height:100%">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-shrink-0">
        <MudText Typo="Typo.h5">Personal</MudText>
        <div class="d-flex gap-2">
            <MudButton Variant="Variant.Outlined" Color="Color.Success"
                       StartIcon="@Icons.Material.Filled.FileDownload"
                       OnClick="ExportExcel" Size="Size.Small">Exportar</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       Href="/personnel/new" Size="Size.Small">Agregar Persona</MudButton>
        </div>
    </div>

    <div class="d-flex gap-2 mb-3 flex-wrap flex-shrink-0">
        <MudTextField @bind-Value="search" @bind-Value:after="Load" Placeholder="Buscar nombre / teléfono…"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true" Clearable="true" Style="max-width:260px"
                      Variant="Variant.Outlined" Margin="Margin.Dense" />
        <MudSelect T="int?" @bind-Value="filterRoleId" @bind-Value:after="Load" Placeholder="Roles"
                   Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:190px">
            @foreach (var role in roles)
            {
                <MudSelectItem T="int?" Value="@((int?)role.RoleId)">@role.Name</MudSelectItem>
            }
        </MudSelect>
        <MudSelect T="string" @bind-Value="filterActive" @bind-Value:after="Load" Placeholder="Estatus"
                   Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:150px">
            <MudSelectItem T="string" Value="@("true")">Activos</MudSelectItem>
            <MudSelectItem T="string" Value="@("false")">Inactivos</MudSelectItem>
            <MudSelectItem T="string" Value="@("pending")">Pendientes por aprobar</MudSelectItem>
        </MudSelect>
        <MudSelect T="string" @bind-Value="filterGroup" @bind-Value:after="Load" Placeholder="Grupo"
                   Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:150px">
            <MudSelectItem T="string" Value="@("regular")">Regulares</MudSelectItem>
            <MudSelectItem T="string" Value="@("mass")">Masivos</MudSelectItem>
        </MudSelect>
    </div>

    <div class="table-scroll flex-grow-1">
        <MudTable Items="@persons" Loading="loading" Dense="true" Hover="true"
                  T="Person" Elevation="2" Class="rounded" Style="font-size:0.85rem"
                  FixedHeader="true"
                  RowClassFunc="@((p, i) => !p.Active ? "mud-text-secondary" : "")">
    <HeaderContent>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<Person, object>(x => x.FullName)">
                Nombre
            </MudTableSortLabel>
        </MudTh>
        <MudTh>Teléfono</MudTh>
        <MudTh>eMail</MudTh>
        <MudTh>Roles</MudTh>
        <MudTh>Grupo</MudTh>
        <MudTh>Estatus</MudTh>
        <MudTh></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Nombre">@context.FullName</MudTd>
        <MudTd DataLabel="Teléfono">@context.PhoneNumber</MudTd>
        <MudTd DataLabel="eMail">@context.Email</MudTd>
        <MudTd DataLabel="Roles">@string.Join(", ", context.PersonRoles.Select(r => r.Role?.Name))</MudTd>
        <MudTd DataLabel="Grupo">
            <MudChip T="string" Color="@(context.IsMassGroup ? Color.Tertiary : Color.Default)" Size="Size.Small"
                     Variant="Variant.Filled" Class="ma-0">
                @(context.IsMassGroup ? "Masivos" : "Regular")
            </MudChip>
        </MudTd>
        <MudTd DataLabel="Estatus">
            @if (context.PendingApproval)
            {
                <MudChip T="string" Color="Color.Warning" Size="Size.Small" Variant="Variant.Filled" Class="ma-0">
                    Pendiente por aprobar
                </MudChip>
            }
            else
            {
                <MudChip T="string" Color="@(context.Active ? Color.Success : Color.Secondary)" Size="Size.Small"
                         Variant="Variant.Filled" Class="ma-0">
                    @(context.Active ? "Activo" : "Inactivo")
                </MudChip>
            }
        </MudTd>
        <MudTd DataLabel="">
            <div style="display:flex; align-items:center; justify-content:flex-end">
                @if (context.PendingApproval)
                {
                    <MudTooltip Text="Aprobar registro">
                        <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Success"
                                       Size="Size.Small" OnClick="() => ConfirmApprove(context)" />
                    </MudTooltip>
                    <MudTooltip Text="Rechazar registro">
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error"
                                       Size="Size.Small" OnClick="() => ConfirmReject(context)" />
                    </MudTooltip>
                }
                <MudTooltip Text="Manejar disponibilidad">
                    <MudIconButton Icon="@Icons.Material.Filled.CalendarMonth" Color="Color.Info"
                                   Size="Size.Small" Href="@($"/personnel/{context.PersonId}/availability")" />
                </MudTooltip>
                <MudTooltip Text="Editar personal">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary"
                                   Size="Size.Small" Href="@($"/personnel/{context.PersonId}")" />
                </MudTooltip>
                <MudTooltip Text="Desactivar personal">
                    <MudIconButton Icon="@Icons.Material.Filled.PersonOff" Color="Color.Error"
                                   Size="Size.Small" OnClick="() => ConfirmDeactivate(context)" />
                </MudTooltip>
            </div>
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText Typo="Typo.body1" Class="py-4 mud-text-secondary" Style="display:block;text-align:center">
            No se encontró personal.
        </MudText>
    </NoRecordsContent>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[] { 25, 50, 100 }" />
    </PagerContent>
        </MudTable>
    </div>
</div>

@code {
    private List<Person> persons = new();
    private List<Role> roles = new();
    private string search = "";
    private string filterActive = "";
    private string filterGroup = "";
    private int? filterRoleId;
    private bool loading = true;
    private string userId = "";

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
        roles = await PersonSvc.GetRolesAsync();
        await Load();
    }

    private async Task Load()
    {
        loading = true;
        bool? active = filterActive == "true" ? true : filterActive == "false" ? false : null;
        bool? pendingApproval = filterActive == "pending" ? true : null;
        bool? isMassGroup = filterGroup == "mass" ? true : filterGroup == "regular" ? false : null;
        persons = await PersonSvc.GetAllAsync(search, filterRoleId, active, isMassGroup, pendingApproval);
        loading = false;
    }

    private async Task ConfirmApprove(Person p)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Aprobar Registro",
            $"¿Desea aprobar el registro de {p.FullName}? Podrá ingresar a la aplicación.",
            yesText: "Sí, aprobar",
            cancelText: "No");

        if (confirmed == true)
        {
            await PersonSvc.ApproveAsync(p.PersonId, userId);
            Snackbar.Add("Registro aprobado", Severity.Success);
            await Load();
        }
    }

    private async Task ConfirmReject(Person p)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Rechazar Registro",
            $"¿Desea rechazar el registro de {p.FullName}? Esta acción no se puede deshacer.",
            yesText: "Sí, rechazar",
            cancelText: "No");

        if (confirmed == true)
        {
            await PersonSvc.RejectAsync(p.PersonId, userId);
            Snackbar.Add("Registro rechazado", Severity.Info);
            await Load();
        }
    }

    private async Task ConfirmDeactivate(Person p)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Desactivar Personal",
            $"¿Desea desactivar a {p.FullName}?",
            yesText: "Sí, desactivar",
            cancelText: "No");

        if (confirmed == true)
        {
            await PersonSvc.SoftDeleteAsync(p.PersonId, userId);
            Snackbar.Add("Personal desactivado", Severity.Info);
            await Load();
        }
    }

    private async Task ExportExcel()
    {
        var bytes = Excel.ExportPersons(persons);
        await JS.InvokeVoidAsync("downloadFile", "personnel.xlsx", Convert.ToBase64String(bytes));
    }
}
