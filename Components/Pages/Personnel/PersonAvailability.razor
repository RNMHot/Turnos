@page "/personnel/{PersonId:int}/availability"
@attribute [Authorize]
@rendermode InteractiveServer
@inject PersonService PersonSvc
@inject AvailabilityService AvailSvc
@inject NavigationManager Nav

<PageTitle>Disponibilidad — Turnos</PageTitle>

<div class="d-flex align-items-center gap-2 mb-3">
    <a href="/personnel" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h4 class="mb-0">Disponibilidad: @person?.FullName</h4>
</div>

@if (person is null)
{
    <p class="text-muted">Cargando…</p>
}
else
{
    <div class="row">
        <div class="col-md-5">
            <div class="card shadow-sm mb-3">
                <div class="card-header fw-bold">Agregar Disponibilidad</div>
                <div class="card-body">
                    <div class="mb-2">
                        <label class="form-label">Tipo</label>
                        <select class="form-select" @bind="newAvailType">
                            <option value="@AvailabilityType.Recurring">Recurrente (semanal)</option>
                            <option value="@AvailabilityType.SpecificDate">Fecha específica</option>
                        </select>
                    </div>
                    @if (newAvailType == AvailabilityType.Recurring)
                    {
                        <div class="mb-2">
                            <label class="form-label">Días de la semana</label>
                            <div class="d-flex gap-2 flex-wrap">
                                @foreach (var day in DayNames)
                                {
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="day_@day"
                                               checked="@selectedDays.Contains(day)"
                                               @onchange="e => ToggleDay(day, (bool)e.Value!)" />
                                        <label class="form-check-label" for="day_@day">@day[..3]</label>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="mb-2">
                            <label class="form-label">Fecha</label>
                            <input type="date" class="form-control" @bind="specificDate" />
                        </div>
                    }
                    <div class="row g-2 mb-2">
                        <div class="col">
                            <label class="form-label">Hora de inicio</label>
                            <input type="time" class="form-control" @bind="startTime" />
                        </div>
                        <div class="col">
                            <label class="form-label">Hora de fin</label>
                            <input type="time" class="form-control" @bind="endTime" />
                        </div>
                    </div>
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" id="unavail" @bind="isUnavailable" />
                        <label class="form-check-label" for="unavail">Marcar como no disponible (bloquear)</label>
                    </div>
                    <button class="btn btn-primary btn-sm" @onclick="AddAvailability">
                        <i class="bi bi-plus me-1"></i>Agregar
                    </button>
                </div>
            </div>
        </div>
        <div class="col-md-7">
            <div class="card shadow-sm">
                <div class="card-header fw-bold">Disponibilidad Actual</div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr><th>Tipo</th><th>Día / Fecha</th><th>Hora</th><th>Estado</th><th></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var a in availabilities)
                            {
                                <tr>
                                    <td>@a.AvailabilityType</td>
                                    <td>
                                        @if (a.AvailabilityType == AvailabilityType.Recurring)
                                            @(a.DaysOfWeek ?? "—")
                                        else
                                            @(a.SpecificDate?.ToString("MMM d, yyyy") ?? "—")
                                    </td>
                                    <td>@a.StartTime.ToString(@"hh\:mm") – @a.EndTime.ToString(@"hh\:mm")</td>
                                    <td>
                                        @if (a.IsUnavailable)
                                        {
                                            <span class="badge bg-danger">No disponible</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Disponible</span>
                                        }
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAvailability(a.AvailabilityId)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                            @if (!availabilities.Any())
                            {
                                <tr><td colspan="5" class="text-muted text-center py-3">No hay disponibilidad establecida.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int PersonId { get; set; }

    private Person? person;
    private List<Availability> availabilities = new();
    private AvailabilityType newAvailType = AvailabilityType.Recurring;
    private List<string> selectedDays = new();
    private DateOnly specificDate = DateOnly.FromDateTime(DateTime.Today);
    private TimeOnly startTime = new TimeOnly(8, 0);
    private TimeOnly endTime = new TimeOnly(20, 0);
    private bool isUnavailable;

    private static readonly string[] DayNames = { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday" };

    protected override async Task OnInitializedAsync()
    {
        person = await PersonSvc.GetByIdAsync(PersonId);
        await LoadAvailabilities();
    }

    private async Task LoadAvailabilities()
    {
        availabilities = await AvailSvc.GetForPersonAsync(PersonId);
    }

    private void ToggleDay(string day, bool selected)
    {
        if (selected) { if (!selectedDays.Contains(day)) selectedDays.Add(day); }
        else selectedDays.Remove(day);
    }

    private async Task AddAvailability()
    {
        var avail = new Availability
        {
            PersonId = PersonId,
            AvailabilityType = newAvailType,
            StartTime = startTime.ToTimeSpan(),
            EndTime = endTime.ToTimeSpan(),
            IsUnavailable = isUnavailable
        };

        if (newAvailType == AvailabilityType.Recurring)
            avail.DaysOfWeek = string.Join(",", selectedDays);
        else
            avail.SpecificDate = specificDate.ToDateTime(TimeOnly.MinValue);

        await AvailSvc.CreateAsync(avail);
        selectedDays.Clear();
        isUnavailable = false;
        await LoadAvailabilities();
    }

    private async Task DeleteAvailability(int id)
    {
        await AvailSvc.DeleteAsync(id);
        await LoadAvailabilities();
    }
}
