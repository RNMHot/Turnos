@page "/assignments/new"
@page "/assignments/{Id:int}"
@attribute [Authorize(Policy = "AppAccess", Roles = "Gerencia,Admin")]
@rendermode InteractiveServer
@inject AssignmentService AssignmentSvc
@inject EventService EventSvc
@inject PersonService PersonSvc
@inject LocationService LocationSvc
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

<PageTitle>@(Id == 0 ? "New Assignment" : "Edit Assignment") — Turnos</PageTitle>

<div class="d-flex align-items-center gap-2 mb-3">
    <a href="/assignments" class="btn btn-outline-secondary btn-sm" title="Regresar"><i class="bi bi-arrow-left"></i></a>
    <h4 class="mb-0">@(Id == 0 ? "New Assignment" : "Edit Assignment")</h4>
</div>

@if (!string.IsNullOrEmpty(saveError))
{
    <div class="alert alert-danger">@saveError</div>
}

<div class="card shadow-sm" style="max-width:600px">
    <div class="card-body">
        <EditForm Model="assignment" OnValidSubmit="Save">
            <DataAnnotationsValidator />

            <div class="mb-3">
                <label class="form-label">Person *</label>
                <InputSelect @bind-Value="assignment.PersonId" class="form-select">
                    <option value="0">— Select person —</option>
                    @foreach (var p in persons)
                    {
                        <option value="@p.PersonId">@p.FullName</option>
                    }
                </InputSelect>
            </div>
            <div class="mb-3">
                <label class="form-label">Event *</label>
                <InputSelect @bind-Value="assignment.EventId" class="form-select" @bind-Value:after="OnEventSelected">
                    <option value="0">— Select event —</option>
                    @foreach (var e in events)
                    {
                        <option value="@e.EventId">@e.EventName (@e.StartDateTime.ToString("MMM d"))</option>
                    }
                </InputSelect>
            </div>

            @if (locationPositions.Count > 0)
            {
                <div class="mb-3">
                    <label class="form-label">Posición</label>
                    <select class="form-select" @bind="positionIdStr">
                        <option value="">— Sin posición —</option>
                        @foreach (var pos in locationPositions)
                        {
                            <option value="@pos.LocationPositionId">@pos.Name</option>
                        }
                    </select>
                </div>
            }

            <div class="row g-2 mb-3">
                <div class="col">
                    <label class="form-label">Inicio</label>
                    <input type="datetime-local" class="form-control" @bind="startLocal" />
                </div>
                <div class="col">
                    <label class="form-label">Fin</label>
                    <input type="datetime-local" class="form-control" @bind="endLocal" />
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Status</label>
                <InputSelect @bind-Value="assignment.Status" class="form-select">
                    @foreach (var s in Enum.GetValues<AssignmentStatus>())
                    {
                        <option value="@s">@s</option>
                    }
                </InputSelect>
            </div>
            <div class="mb-3">
                <label class="form-label">Notes</label>
                <InputTextArea @bind-Value="assignment.Notes" class="form-control" rows="2" />
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary" disabled="@saving">@(saving ? "Saving…" : "Save")</button>
                <a href="/assignments" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter] public int Id { get; set; }

    private Assignment assignment = new() { Status = AssignmentStatus.Candidato };
    private List<Person> persons = new();
    private List<Event> events = new();
    private List<LocationPosition> locationPositions = new();
    private bool saving;
    private string? saveError;
    private string userId = "";
    private DateTime startLocal = DateTime.Now;
    private DateTime endLocal = DateTime.Now.AddHours(4);

    private string positionIdStr
    {
        get => assignment.LocationPositionId?.ToString() ?? "";
        set => assignment.LocationPositionId = string.IsNullOrEmpty(value) ? null : int.Parse(value);
    }

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
        persons = await PersonSvc.GetAllAsync(active: true);
        events = await EventSvc.GetAllAsync(active: true);

        if (Id != 0)
        {
            var existing = await AssignmentSvc.GetByIdAsync(Id);
            if (existing is not null)
            {
                assignment = existing;
                startLocal = ToLocal(assignment.StartDateTime);
                endLocal = ToLocal(assignment.EndDateTime);

                var ev = events.FirstOrDefault(e => e.EventId == assignment.EventId);
                if (ev?.LocationId.HasValue == true)
                    locationPositions = await LocationSvc.GetPositionsAsync(ev.LocationId.Value);
            }
        }
    }

    private static DateTime ToLocal(DateTime dt) =>
        dt.Kind == DateTimeKind.Utc ? dt.ToLocalTime() : dt;

    private async Task OnEventSelected()
    {
        var ev = events.FirstOrDefault(e => e.EventId == assignment.EventId);
        if (ev is not null)
        {
            startLocal = ToLocal(ev.StartDateTime);
            endLocal = ToLocal(ev.EndDateTime);

            if (ev.LocationId.HasValue)
                locationPositions = await LocationSvc.GetPositionsAsync(ev.LocationId.Value);
            else
                locationPositions = new();

            assignment.LocationPositionId = null;
        }
    }

    private async Task Save()
    {
        saving = true;
        saveError = null;
        assignment.StartDateTime = startLocal;
        assignment.EndDateTime = endLocal;

        var (success, err) = Id == 0
            ? await AssignmentSvc.CreateAsync(assignment, userId)
            : await AssignmentSvc.UpdateAsync(assignment, userId);

        if (success)
            Nav.NavigateTo("/assignments");
        else
        {
            saveError = err;
            saving = false;
        }
    }
}
