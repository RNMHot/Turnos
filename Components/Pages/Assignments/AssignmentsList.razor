@page "/assignments"
@attribute [Authorize(Policy = "AppAccess", Roles = "Gerencia,Admin")]
@rendermode InteractiveServer
@inject AssignmentService AssignmentSvc
@inject ExcelExportService Excel
@inject AuthenticationStateProvider AuthState
@inject IJSRuntime JS
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Asignados — Turnos</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <MudText Typo="Typo.h5">Asignados</MudText>
    <div class="d-flex gap-2">
        <MudButton Variant="Variant.Outlined" Color="Color.Success"
                   StartIcon="@Icons.Material.Filled.FileDownload"
                   OnClick="ExportExcel" Size="Size.Small">Exportar</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   Href="/assignments/new" Size="Size.Small">Nueva Asignación</MudButton>
    </div>
</div>

<MudTextField @bind-Value="_searchString" Placeholder="Buscar persona, evento o cliente..."
              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
              Immediate="true" Clearable="true" Class="mb-3" Style="max-width:400px"
              Variant="Variant.Outlined" Margin="Margin.Dense" />

<MudTable Items="@assignments" Dense="true" Hover="true"
          Filter="@FilterFunc" OnRowClick="@OpenDetailDialog"
          T="Assignment" Elevation="2" Class="rounded" Style="font-size:0.85rem"
          RowClass="cursor-pointer">
    <HeaderContent>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<Assignment, object>(x => x.Person?.FullName ?? string.Empty)">
                Persona
            </MudTableSortLabel>
        </MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<Assignment, object>(x => x.Event?.EventName ?? string.Empty)">
                Evento
            </MudTableSortLabel>
        </MudTh>
        <MudTh>Cliente</MudTh>
        <MudTh>Posición</MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<Assignment, object>(x => x.StartDateTime)">
                Inicio
            </MudTableSortLabel>
        </MudTh>
        <MudTh>Fin</MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<Assignment, object>(x => x.Status)">
                Estatus
            </MudTableSortLabel>
        </MudTh>
        <MudTh></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Persona">@context.Person?.FullName</MudTd>
        <MudTd DataLabel="Evento">@context.Event?.EventName</MudTd>
        <MudTd DataLabel="Cliente">@(context.Event?.Company?.Name ?? "—")</MudTd>
        <MudTd DataLabel="Posición">@(context.LocationPosition?.Name ?? "—")</MudTd>
        <MudTd DataLabel="Inicio">@context.StartDateTime.ToString("MMM d, h:mm tt")</MudTd>
        <MudTd DataLabel="Fin">@context.EndDateTime.ToString("h:mm tt")</MudTd>
        <MudTd DataLabel="Estatus">
            <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small"
                     Variant="Variant.Filled" Class="ma-0">
                @context.Status
            </MudChip>
        </MudTd>
        <MudTd DataLabel="" @onclick:stopPropagation="true">
            <div style="display:flex; align-items:center; justify-content:flex-end">
                <MudTooltip Text="Enviar WhatsApp">
                    <MudIconButton Icon="@Icons.Custom.Brands.WhatsApp" Color="Color.Success"
                                   Size="Size.Small" OnClick="() => OpenMessage(context)" />
                </MudTooltip>
                <MudTooltip Text="Editar">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary"
                                   Size="Size.Small" Href="@($"/assignments/{context.AssignmentId}")" />
                </MudTooltip>
                <MudTooltip Text="Eliminar">
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                   Size="Size.Small" OnClick="() => ConfirmDelete(context)" />
                </MudTooltip>
            </div>
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText Typo="Typo.body1" Class="py-4 mud-text-secondary" Style="display:block;text-align:center">
            No se encontraron asignaciones.
        </MudText>
    </NoRecordsContent>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[] { 25, 50, 100 }" />
    </PagerContent>
</MudTable>

<MessageModal Show="showMessage" PersonId="messagePersonId" EventId="messageEventId" OnClose="CloseMessage" />

@code {
    private List<Assignment> assignments = new();
    private string userId = "";
    private string _searchString = "";
    private bool showMessage;
    private int? messagePersonId;
    private int? messageEventId;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
        await Load();
    }

    private async Task Load() => assignments = await AssignmentSvc.GetAllAsync();

    private bool FilterFunc(Assignment a) =>
        string.IsNullOrWhiteSpace(_searchString)
        || (a.Person?.FullName?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false)
        || (a.Event?.EventName?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false)
        || (a.Event?.Company?.Name?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false)
        || (a.LocationPosition?.Name?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false);

    private async Task OpenDetailDialog(TableRowClickEventArgs<Assignment> args)
    {
        var parameters = new DialogParameters<AssignmentDetailDialog>
        {
            { x => x.Assignment, args.Item }
        };
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseButton = true
        };
        var dialog = await DialogService.ShowAsync<AssignmentDetailDialog>(
            "Detalle de Asignación", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            if (result.Data is AssignmentStatus)
            {
                Snackbar.Add("Estatus actualizado", Severity.Success);
                await Load();
            }
            else if (result.Data is string action && action == "whatsapp")
            {
                OpenMessage(args.Item!);
            }
        }
    }

    private async Task ConfirmDelete(Assignment a)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Eliminar Asignación",
            $"¿Desea eliminar la asignación de {a.Person?.FullName} — {a.Event?.EventName}?",
            yesText: "Sí, eliminar",
            cancelText: "No");

        if (confirmed == true)
        {
            await AssignmentSvc.DeleteAsync(a.AssignmentId, userId);
            Snackbar.Add("Asignación eliminada", Severity.Info);
            await Load();
        }
    }

    private void OpenMessage(Assignment a)
    {
        messagePersonId = a.PersonId;
        messageEventId = a.EventId;
        showMessage = true;
    }

    private void CloseMessage() => showMessage = false;

    private async Task ExportExcel()
    {
        var bytes = Excel.ExportAssignments(assignments);
        await JS.InvokeVoidAsync("downloadFile", "assignments.xlsx", Convert.ToBase64String(bytes));
    }

    private static Color GetStatusColor(AssignmentStatus status) => status switch
    {
        AssignmentStatus.Confirmado => Color.Success,
        AssignmentStatus.Asignado   => Color.Primary,
        AssignmentStatus.Ofrecido   => Color.Info,
        AssignmentStatus.Disponible => Color.Secondary,
        AssignmentStatus.Candidato  => Color.Default,
        _                           => Color.Default
    };
}
