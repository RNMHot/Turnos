@page "/settings/change-password"
@attribute [Authorize]
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Identity
@inject AuthenticationStateProvider AuthStateProvider
@inject UserManager<IdentityUser> UserManager

<PageTitle>Cambiar contraseña — Turnos</PageTitle>

<div class="d-flex align-items-center mb-4 gap-3">
    <a href="/settings" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
    <h4 class="mb-0"><i class="bi bi-key me-2"></i>Cambiar contraseña</h4>
</div>

<div class="card" style="max-width:480px">
    <div class="card-body">
        <p class="text-muted small mb-3">
            Ingrese su contraseña actual y luego la nueva contraseña que desea usar.
        </p>

        <div class="mb-3">
            <label class="form-label">Contraseña actual</label>
            <input type="password" class="form-control" @bind="_current" autocomplete="current-password" />
        </div>

        <div class="mb-3">
            <label class="form-label">Nueva contraseña</label>
            <input type="password" class="form-control" @bind="_new" autocomplete="new-password" />
        </div>

        <div class="mb-3">
            <label class="form-label">Confirmar nueva contraseña</label>
            <input type="password" class="form-control" @bind="_confirm" autocomplete="new-password" />
        </div>

        <button class="btn btn-primary" @onclick="Save" disabled="@_busy">
            @if (_busy)
            {
                <span class="spinner-border spinner-border-sm me-1"></span>
            }
            else
            {
                <i class="bi bi-check-lg me-1"></i>
            }
            Guardar
        </button>

        @if (!string.IsNullOrEmpty(_message))
        {
            <div class="alert @_alertClass mt-3 py-2 mb-0">@_message</div>
        }
    </div>
</div>

@code {
    private string _current = "";
    private string _new = "";
    private string _confirm = "";
    private string _message = "";
    private string _alertClass = "alert-success";
    private bool _busy;

    private async Task Save()
    {
        _message = "";

        if (string.IsNullOrWhiteSpace(_current) || string.IsNullOrWhiteSpace(_new) || string.IsNullOrWhiteSpace(_confirm))
        {
            _message = "Todos los campos son obligatorios.";
            _alertClass = "alert-danger";
            return;
        }

        if (_new != _confirm)
        {
            _message = "La nueva contraseña y su confirmación no coinciden.";
            _alertClass = "alert-danger";
            return;
        }

        _busy = true;
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = await UserManager.GetUserAsync(authState.User);
            if (user is null)
            {
                _message = "No se pudo identificar al usuario.";
                _alertClass = "alert-danger";
                return;
            }

            var result = await UserManager.ChangePasswordAsync(user, _current, _new);
            if (result.Succeeded)
            {
                _message = "Contraseña actualizada correctamente.";
                _alertClass = "alert-success";
                _current = _new = _confirm = "";
            }
            else
            {
                var errors = string.Join(" ", result.Errors.Select(e => e.Description));
                _message = $"Error: {errors}";
                _alertClass = "alert-danger";
            }
        }
        finally
        {
            _busy = false;
        }
    }
}
