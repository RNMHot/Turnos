@page "/settings/user-sessions"
@attribute [Authorize(Policy = "AppAccess", Roles = "Admin")]
@rendermode InteractiveServer
@inject UserSessionService SessionSvc
@inject AppSettingsState SettingsState

<PageTitle>Sesiones de usuario — Turnos</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h4 class="mb-0"><i class="bi bi-person-lines-fill me-2"></i>Sesiones de usuario</h4>
    <button class="btn btn-outline-secondary btn-sm" @onclick="Load">
        <i class="bi bi-arrow-clockwise me-1"></i>Actualizar
    </button>
</div>

<div class="d-flex gap-2 mb-3 flex-wrap align-items-center">
    <input type="date" class="form-control form-control-sm" style="max-width:150px" @bind="filterFrom" @bind:after="Load" />
    <input type="date" class="form-control form-control-sm" style="max-width:150px" @bind="filterTo" @bind:after="Load" />
    <div class="form-check ms-2">
        <input class="form-check-input" type="checkbox" id="onlyConnected" @bind="onlyConnected" @bind:after="Load" />
        <label class="form-check-label" for="onlyConnected">Solo conectados ahora</label>
    </div>
    <span class="text-muted small ms-auto">@connectedCount conectado(s) ahora mismo</span>
</div>

<div class="table-responsive flex-grow-1" style="overflow-y:auto; min-height:0;">
    <table class="table table-sm align-middle">
        <thead class="table-light" style="position:sticky; top:0; z-index:1;">
            <tr>
                <th>Usuario</th>
                <th>Ingreso</th>
                <th>Salida</th>
                <th>Estado</th>
                <th>IP</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var s in sessions)
        {
            <tr>
                <td>
                    <div>@(string.IsNullOrWhiteSpace(s.PersonName) ? s.Email : s.PersonName)</div>
                    <div class="text-muted small">@s.Email</div>
                </td>
                <td class="text-nowrap">@SettingsState.ToDisplay(s.LoginAt).ToString(format: "yyyy-MM-dd h:mm tt")</td>
                <td class="text-nowrap">@(s.LogoutAt.HasValue ? SettingsState.ToDisplay(s.LogoutAt.Value).ToString(format: "yyyy-MM-dd h:mm tt") : "—")</td>
                <td>@StatusBadge(s)</td>
                <td class="text-muted small">@(s.IpAddress ?? "—")</td>
            </tr>
        }
        @if (!sessions.Any())
        {
            <tr><td colspan="5" class="text-muted text-center py-4">No hay sesiones registradas.</td></tr>
        }
        </tbody>
    </table>
</div>

@code {
    private List<UserSession> sessions = new();
    private DateTime? filterFrom;
    private DateTime? filterTo;
    private bool onlyConnected;
    private int connectedCount;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        var fromUtc = filterFrom.HasValue ? SettingsState.ToUtc(filterFrom.Value) : (DateTime?)null;
        var toUtc = filterTo.HasValue ? SettingsState.ToUtc(filterTo.Value.AddDays(1).AddTicks(-1)) : (DateTime?)null;

        sessions = await SessionSvc.GetSessionsAsync(fromUtc, toUtc, onlyConnected);
        connectedCount = sessions.Count(s => s.LogoutAt == null && s.ConnectedCircuits > 0);
    }

    private static MarkupString StatusBadge(UserSession s)
    {
        if (s.LogoutAt.HasValue)
            return new MarkupString("<span class=\"badge bg-secondary\">Sesión cerrada</span>");

        if (s.ConnectedCircuits > 0)
            return new MarkupString("<span class=\"badge bg-success\">Conectado</span>");

        return new MarkupString("<span class=\"badge bg-warning text-dark\">Desconectado</span>");
    }
}
