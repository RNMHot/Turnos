@page "/settings/email"
@attribute [Authorize(Policy = "AppAccess", Roles = "Gerencia,Admin")]
@rendermode InteractiveServer
@inject AppSettingService SettingsSvc

<PageTitle>Cuenta de correo electrónico — Turnos</PageTitle>

<div class="d-flex align-items-center mb-4 gap-3">
    <a href="/settings" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
    <h4 class="mb-0"><i class="bi bi-envelope me-2"></i>Cuenta de correo electrónico</h4>
</div>

<div class="card" style="max-width:600px">
    <div class="card-body">
        <p class="text-muted small mb-3">
            Configure los datos de la cuenta de correo electrónico utilizada para enviar eMails a los usuarios del sistema.
        </p>

        <div class="mb-3">
            <label class="form-label">Servidor SMTP</label>
            <input type="text" class="form-control" @bind="_smtpHost" placeholder="Ej: smtp.gmail.com" />
        </div>

        <div class="mb-3">
            <label class="form-label">Puerto SMTP</label>
            <input type="number" class="form-control" @bind="_smtpPort" placeholder="Ej: 587" style="max-width:140px" />
        </div>

        <div class="mb-3 form-check">
            <input type="checkbox" class="form-check-input" id="chkSsl" @bind="_useSsl" />
            <label class="form-check-label" for="chkSsl">Usar SSL / TLS</label>
        </div>

        <div class="mb-3">
            <label class="form-label">Dirección de correo remitente</label>
            <input type="email" class="form-control" @bind="_fromAddress" placeholder="Ej: no-reply@miempresa.com" />
        </div>

        <div class="mb-3">
            <label class="form-label">Nombre del remitente</label>
            <input type="text" class="form-control" @bind="_fromName" placeholder="Ej: Turnos" />
        </div>

        <div class="mb-3">
            <label class="form-label">Usuario</label>
            <input type="text" class="form-control" @bind="_username" placeholder="Ej: no-reply@miempresa.com" />
        </div>

        <div class="mb-3">
            <label class="form-label">Contraseña</label>
            <input type="password" class="form-control" @bind="_password" placeholder="Contraseña de la cuenta" />
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-primary" @onclick="Save">
                <i class="bi bi-check-lg me-1"></i>Guardar
            </button>
        </div>

        @if (!string.IsNullOrEmpty(_message))
        {
            <div class="alert @_messageClass mt-3 py-2 mb-0">@_message</div>
        }
    </div>
</div>

@code {
    private string _smtpHost = "";
    private int _smtpPort = 587;
    private bool _useSsl = true;
    private string _fromAddress = "";
    private string _fromName = "";
    private string _username = "";
    private string _password = "";
    private string _message = "";
    private string _messageClass = "alert-success";

    protected override async Task OnInitializedAsync()
    {
        _smtpHost    = await SettingsSvc.GetValueAsync("Email.SmtpHost") ?? "";
        _fromAddress = await SettingsSvc.GetValueAsync("Email.FromAddress") ?? "";
        _fromName    = await SettingsSvc.GetValueAsync("Email.FromName") ?? "";
        _username    = await SettingsSvc.GetValueAsync("Email.Username") ?? "";
        _password    = await SettingsSvc.GetValueAsync("Email.Password") ?? "";

        var portStr = await SettingsSvc.GetValueAsync("Email.SmtpPort");
        if (int.TryParse(portStr, out var port)) _smtpPort = port;

        var sslStr = await SettingsSvc.GetValueAsync("Email.UseSsl");
        _useSsl = !string.Equals(sslStr, "false", StringComparison.OrdinalIgnoreCase);
    }

    private async Task Save()
    {
        try
        {
            await SettingsSvc.SetValueAsync("Email.SmtpHost",    NullIfEmpty(_smtpHost));
            await SettingsSvc.SetValueAsync("Email.SmtpPort",    _smtpPort.ToString());
            await SettingsSvc.SetValueAsync("Email.UseSsl",      _useSsl.ToString().ToLower());
            await SettingsSvc.SetValueAsync("Email.FromAddress", NullIfEmpty(_fromAddress));
            await SettingsSvc.SetValueAsync("Email.FromName",    NullIfEmpty(_fromName));
            await SettingsSvc.SetValueAsync("Email.Username",    NullIfEmpty(_username));
            await SettingsSvc.SetValueAsync("Email.Password",    NullIfEmpty(_password));
            _message = "Configuración guardada correctamente.";
            _messageClass = "alert-success";
        }
        catch
        {
            _message = "Ocurrió un error al guardar la configuración.";
            _messageClass = "alert-danger";
        }
    }

    private static string? NullIfEmpty(string s) => string.IsNullOrWhiteSpace(s) ? null : s;
}
