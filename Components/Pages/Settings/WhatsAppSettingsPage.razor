@page "/settings/whatsapp"
@attribute [Authorize]
@rendermode InteractiveServer
@inject AppSettingService SettingsSvc

<PageTitle>Cuenta de WhatsApp — Turnos</PageTitle>

<div class="d-flex align-items-center mb-4 gap-3">
    <a href="/settings" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
    <h4 class="mb-0"><i class="bi bi-whatsapp me-2"></i>Cuenta de WhatsApp</h4>
</div>

<div class="card" style="max-width:600px">
    <div class="card-body">
        <p class="text-muted small mb-3">
            Configure los datos de la cuenta de WhatsApp Business utilizada para enviar mensajes a los usuarios del sistema.
        </p>

        <div class="mb-3">
            <label class="form-label">Número de teléfono</label>
            <input type="tel" class="form-control" @bind="_phoneNumber" placeholder="Ej: +1234567890" />
            <div class="form-text">Número de teléfono asociado a la cuenta de WhatsApp Business.</div>
        </div>

        <div class="mb-3">
            <label class="form-label">Token de acceso (API)</label>
            <input type="password" class="form-control" @bind="_apiToken" placeholder="Token de la API de WhatsApp Business" />
            <div class="form-text">Token de acceso permanente generado en Meta for Developers.</div>
        </div>

        <div class="mb-3">
            <label class="form-label">ID de cuenta de negocio</label>
            <input type="text" class="form-control" @bind="_businessAccountId" placeholder="Ej: 123456789012345" />
            <div class="form-text">Business Account ID de la cuenta en Meta Business Suite.</div>
        </div>

        <div class="mb-3">
            <label class="form-label">ID del número de teléfono</label>
            <input type="text" class="form-control" @bind="_phoneNumberId" placeholder="Ej: 987654321098765" />
            <div class="form-text">Phone Number ID obtenido en la consola de Meta for Developers.</div>
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-primary" @onclick="Save">
                <i class="bi bi-check-lg me-1"></i>Guardar
            </button>
        </div>

        @if (!string.IsNullOrEmpty(_message))
        {
            <div class="alert @_messageClass mt-3 py-2 mb-0">@_message</div>
        }
    </div>
</div>

@code {
    private string _phoneNumber = "";
    private string _apiToken = "";
    private string _businessAccountId = "";
    private string _phoneNumberId = "";
    private string _message = "";
    private string _messageClass = "alert-success";

    protected override async Task OnInitializedAsync()
    {
        _phoneNumber        = await SettingsSvc.GetValueAsync("WhatsApp.PhoneNumber") ?? "";
        _apiToken           = await SettingsSvc.GetValueAsync("WhatsApp.ApiToken") ?? "";
        _businessAccountId  = await SettingsSvc.GetValueAsync("WhatsApp.BusinessAccountId") ?? "";
        _phoneNumberId      = await SettingsSvc.GetValueAsync("WhatsApp.PhoneNumberId") ?? "";
    }

    private async Task Save()
    {
        try
        {
            await SettingsSvc.SetValueAsync("WhatsApp.PhoneNumber",       NullIfEmpty(_phoneNumber));
            await SettingsSvc.SetValueAsync("WhatsApp.ApiToken",          NullIfEmpty(_apiToken));
            await SettingsSvc.SetValueAsync("WhatsApp.BusinessAccountId", NullIfEmpty(_businessAccountId));
            await SettingsSvc.SetValueAsync("WhatsApp.PhoneNumberId",     NullIfEmpty(_phoneNumberId));
            _message = "Configuración guardada correctamente.";
            _messageClass = "alert-success";
        }
        catch
        {
            _message = "Ocurrió un error al guardar la configuración.";
            _messageClass = "alert-danger";
        }
    }

    private static string? NullIfEmpty(string s) => string.IsNullOrWhiteSpace(s) ? null : s;
}
