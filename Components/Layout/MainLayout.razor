@inherits LayoutComponentBase
@attribute [Authorize(Policy = "AppAccess")]
@implements IDisposable
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="page @(_sidebarCollapsed ? "sidebar-collapsed" : "")">
    <div class="sidebar">
        <NavMenu Collapsed="@_sidebarCollapsed" />
    </div>

    <main>
        <div id="top-row" class="top-row px-4 d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-2">
                <button class="sidebar-toggle-btn" @onclick="ToggleSidebar" title="Alternar menú">
                    <i class="bi bi-list"></i>
                </button>
                <span class="fw-bold text-white">@TopRowTitle</span>
            </div>
            <AuthorizeView>
                <Authorized>
                    <span class="me-3 text-white small">@context.User.Identity?.Name</span>
                    <a href="/account/logout" class="btn btn-sm btn-outline-light">Salir</a>
                </Authorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">&#x2715;</span>
</div>

@code {
    private bool _sidebarCollapsed = false;
    private bool _isUjier = false;

    private string TopRowTitle
    {
        get
        {
            if (!_isUjier) return "Turnos — Manejo de Eventos";
            if (Nav.Uri.Contains("/attendance/checkin", StringComparison.OrdinalIgnoreCase)) return "Registro de Asistencia";
            if (Nav.Uri.Contains("/supervisor", StringComparison.OrdinalIgnoreCase)) return "Panel de Supervisor";
            return "Turnos — Manejo de Eventos";
        }
    }

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#17324D",
            Secondary = "#5B6F86",
            Tertiary = "#C97832",
            Success = "#2FA36B",
            Warning = "#D99A1B",
            Error = "#C94848",
            Info = "#2D8C91",
            Background = "#F5F7FA",
            TextPrimary = "#1C2430",
        }
    };

    private void ToggleSidebar() => _sidebarCollapsed = !_sidebarCollapsed;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _isUjier = !(authState.User.IsInRole("Gerencia") || authState.User.IsInRole("Admin"));

        Nav.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e) => InvokeAsync(StateHasChanged);

    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;
}
