@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex justify-content-between align-items-center">
            <span class="fw-bold text-muted">Turnos — Event Staffing</span>
            <AuthorizeView>
                <Authorized>
                    <span class="me-3 text-muted small">@context.User.Identity?.Name</span>
                    <a href="/account/logout" class="btn btn-sm btn-outline-secondary">Logout</a>
                </Authorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">&#x2715;</span>
</div>
