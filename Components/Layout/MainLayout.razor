@inherits LayoutComponentBase
@attribute [Authorize(Policy = "AppAccess")]
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<div class="page @(_sidebarCollapsed ? "sidebar-collapsed" : "")">
    <div class="sidebar">
        <NavMenu Collapsed="@_sidebarCollapsed" />
    </div>

    <main>
        <div id="top-row" class="top-row px-4 d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-2">
                <button class="sidebar-toggle-btn" @onclick="ToggleSidebar" title="Alternar menú">
                    <i class="bi bi-list"></i>
                </button>
                <span class="fw-bold text-muted">Turnos — Personal de Eventos</span>
            </div>
            <AuthorizeView>
                <Authorized>
                    <span class="me-3 text-muted small">@context.User.Identity?.Name</span>
                    <a href="/account/logout" class="btn btn-sm btn-outline-secondary">Salir</a>
                </Authorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">&#x2715;</span>
</div>

@code {
    private bool _sidebarCollapsed = false;
    private bool _checkedAccess;

    private void ToggleSidebar() => _sidebarCollapsed = !_sidebarCollapsed;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_checkedAccess)
            return;

        _checkedAccess = true;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var isCheckInOnly = string.Equals(
            authState.User.FindFirst(TurnosClaimTypes.CheckInOnly)?.Value,
            "true",
            StringComparison.OrdinalIgnoreCase);

        if (!isCheckInOnly)
            return;

        var path = Nav.ToBaseRelativePath(Nav.Uri).Trim('/').ToLowerInvariant();
        var isCheckInPage = path == "attendance/checkin";

        if (!isCheckInPage)
            Nav.NavigateTo("/attendance/checkin", forceLoad: true);
    }
}
