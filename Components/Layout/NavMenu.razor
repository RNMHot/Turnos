@rendermode InteractiveServer
@inject AuthenticationStateProvider AuthStateProvider

<div class="nav-container @(Collapsed ? "nav-collapsed" : "")">
    <div class="top-row ps-3 navbar navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">
                <i class="bi bi-calendar-week me-1"></i><span class="brand-text"> Turnos</span>
            </a>
            <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
                <span class="navbar-toggler-icon"></span>
            </button>
        </div>
    </div>

    <div class="@NavMenuCssClass nav-scrollable" @onclick="CollapseNavMenu">
        <nav class="flex-column">
            @if (!isCheckInOnly)
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/" Match="NavLinkMatch.All" title="Calendario de eventos">
                        <i class="bi bi-grid-3x3-gap me-2"></i><span class="nav-text">Calendario</span>
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/events-columns" title="Eventos por columnas">
                        <i class="bi bi-columns-gap me-2"></i><span class="nav-text">Eventos</span>
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/events" title="Listado de eventos">
                        <i class="bi bi-calendar-event me-2"></i><span class="nav-text">Registro de eventos</span>
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/assignments" title="Ujieres asignados">
                        <i class="bi bi-person-check me-2"></i><span class="nav-text">Personal Asignado</span>
                    </NavLink>
                </div>
                <AuthorizeView Roles="Admin">
                    <Authorized>
                        <div class="nav-item px-3">
                            <NavLink class="nav-link" href="/attendance" title="Asistencia por evento">
                                <i class="bi bi-clock me-2"></i><span class="nav-text">Asistencia</span>
                            </NavLink>
                        </div>
                    </Authorized>
                </AuthorizeView>

                <hr class="my-2 opacity-25 nav-hr" />

                <div class="nav-item px-3">
                    <button class="nav-link btn btn-link w-100 text-start d-flex align-items-center gap-1"
                            @onclick="ToggleRegistros" @onclick:stopPropagation="true" title="Registros del sistema">
                        <i class="bi bi-archive me-2"></i>
                        <span class="nav-text flex-grow-1">Registros</span>
                        <i class="bi @(showRegistros ? "bi-chevron-up" : "bi-chevron-down") small opacity-75 chevron-icon"></i>
                    </button>
                </div>
                @if (showRegistros)
                {
                    <div class="nav-sub" @onclick:stopPropagation="true">
                        <div class="nav-item px-3 ps-4">
                            <NavLink class="nav-link nav-link-sub" href="/personnel" title="Listado de personal">
                                <i class="bi bi-people me-2"></i><span class="nav-text">Personal</span>
                            </NavLink>
                        </div>
                        <div class="nav-item px-3 ps-4">
                            <NavLink class="nav-link nav-link-sub" href="/companies" title="Listado de clientes">
                                <i class="bi bi-building me-2"></i><span class="nav-text">Clientes</span>
                            </NavLink>
                        </div>
                        <div class="nav-item px-3 ps-4">
                            <NavLink class="nav-link nav-link-sub" href="/locations" title="Listado de localidades">
                                <i class="bi bi-geo-alt me-2"></i><span class="nav-text">Localidades</span>
                            </NavLink>
                        </div>
                    </div>
                }

                <hr class="my-2 opacity-25 nav-hr" />

                <div class="nav-item px-3">
                    <button class="nav-link btn btn-link w-100 text-start d-flex align-items-center gap-1"
                            @onclick="ToggleConfig" @onclick:stopPropagation="true">
                        <i class="bi bi-gear me-2"></i>
                        <span class="nav-text flex-grow-1">Configuraciones</span>
                        <i class="bi @(showConfig ? "bi-chevron-up" : "bi-chevron-down") small opacity-75 chevron-icon"></i>
                    </button>
                </div>
                @if (showConfig)
                {
                    <div class="nav-sub" @onclick:stopPropagation="true">
                        <div class="nav-item px-3 ps-4">
                            <NavLink class="nav-link nav-link-sub" href="/messagelog">
                                <i class="bi bi-whatsapp me-2"></i><span class="nav-text">Mensajes</span>
                            </NavLink>
                        </div>
                        <div class="nav-item px-3 ps-4">
                            <NavLink class="nav-link nav-link-sub" href="/auditlog">
                                <i class="bi bi-clock-history me-2"></i><span class="nav-text">Auditoría</span>
                            </NavLink>
                        </div>
                    </div>
                }
            }

            <div class="nav-item px-3">
                <button class="nav-link btn btn-link w-100 text-start d-flex align-items-center gap-1"
                        @onclick="ToggleHerramientas" @onclick:stopPropagation="true" title="Herramientas de trabajo">
                    <i class="bi bi-tools me-2"></i>
                    <span class="nav-text flex-grow-1">Herramientas</span>
                    <i class="bi @(showHerramientas ? "bi-chevron-up" : "bi-chevron-down") small opacity-75 chevron-icon"></i>
                </button>
            </div>
            @if (showHerramientas)
            {
                <div class="nav-sub" @onclick:stopPropagation="true">
                    <div class="nav-item px-3 ps-4">
                        <AuthorizeView Roles="User,Admin">
                            <Authorized>
                                <NavLink class="nav-link nav-link-sub" href="/attendance/checkin" title="Registro rapido de asistencia">
                                    <i class="bi bi-phone me-2"></i><span class="nav-text">Ponchador</span>
                                </NavLink>
                            </Authorized>
                        </AuthorizeView>
                    </div>
                </div>
            }
        </nav>
    </div>
</div>

@code {
    [Parameter] public bool Collapsed { get; set; }

    private bool collapseNavMenu = true;
    private bool showRegistros = false;
    private bool showConfig = false;
    private bool showHerramientas = true;
    private bool isCheckInOnly;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        isCheckInOnly = string.Equals(
            authState.User.FindFirst(TurnosClaimTypes.CheckInOnly)?.Value,
            "true",
            StringComparison.OrdinalIgnoreCase);
    }

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;
    private void ToggleNavMenu() => collapseNavMenu = !collapseNavMenu;
    private void CollapseNavMenu() => collapseNavMenu = true;
    private void ToggleRegistros() => showRegistros = !showRegistros;
    private void ToggleConfig() => showConfig = !showConfig;
    private void ToggleHerramientas() => showHerramientas = !showHerramientas;
}
