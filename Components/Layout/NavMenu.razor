@rendermode InteractiveServer

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="/">
            <i class="bi bi-calendar-week me-1"></i> Turnos
        </a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="CollapseNavMenu">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/" Match="NavLinkMatch.All" title="Calendario de eventos">
                <i class="bi bi-grid-3x3-gap me-2"></i> Calendario
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/events-columns" title="Eventos por columnas">
                <i class="bi bi-columns-gap me-2"></i> Eventos por columnas
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/events" title="Listado de eventos">

                <i class="bi bi-calendar-event me-2"></i> Eventos
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/assignments" title="Ujieres asignados">
                <i class="bi bi-person-check me-2"></i> Asignados
            </NavLink>
        </div>

        <hr class="my-2 opacity-25" />

        <!-- Registros collapsible group -->
        <div class="nav-item px-3">
            <button class="nav-link btn btn-link w-100 text-start d-flex align-items-center gap-1"
                    @onclick="ToggleRegistros" @onclick:stopPropagation="true" title="Registros del sistema">
                <i class="bi bi-archive me-2"></i>
                <span class="flex-grow-1">Registros</span>
                <i class="bi @(showRegistros ? "bi-chevron-up" : "bi-chevron-down") small opacity-75"></i>
            </button>
        </div>
        @if (showRegistros)
        {
            <div class="nav-sub" @onclick:stopPropagation="true">
                <div class="nav-item px-3 ps-4">
                    <NavLink class="nav-link nav-link-sub" href="/personnel" title="Listado de personal">
                        <i class="bi bi-people me-2"></i> Personal
                    </NavLink>
                </div>
                <div class="nav-item px-3 ps-4">
                    <NavLink class="nav-link nav-link-sub" href="/companies" title="Listado de clientes">
                        <i class="bi bi-building me-2"></i> Clientes
                    </NavLink>
                </div>
                <div class="nav-item px-3 ps-4">
                    <NavLink class="nav-link nav-link-sub" href="/locations" title="Listado de localidades">
                        <i class="bi bi-geo-alt me-2"></i> Localidades
                    </NavLink>
                </div>
                <div class="nav-item px-3 ps-4">
                    <NavLink class="nav-link nav-link-sub" href="/records" title="Listado de registros">
                        <i class="bi bi-journal-text me-2"></i> Records
                    </NavLink>
                </div>
            </div>
        }

        <hr class="my-2 opacity-25" />

        <!-- Configuraciones collapsible group -->
        <div class="nav-item px-3">
            <button class="nav-link btn btn-link w-100 text-start d-flex align-items-center gap-1"
                    @onclick="ToggleConfig" @onclick:stopPropagation="true">
                <i class="bi bi-gear me-2"></i>
                <span class="flex-grow-1">Configuraciones</span>
                <i class="bi @(showConfig ? "bi-chevron-up" : "bi-chevron-down") small opacity-75"></i>
            </button>
        </div>
        @if (showConfig)
        {
            <div class="nav-sub" @onclick:stopPropagation="true">
                <div class="nav-item px-3 ps-4">
                    <NavLink class="nav-link nav-link-sub" href="/messagelog">
                        <i class="bi bi-whatsapp me-2"></i> Mensajes 
                    </NavLink>
                </div>
                <div class="nav-item px-3 ps-4">
                    <NavLink class="nav-link nav-link-sub" href="/auditlog">
                        <i class="bi bi-clock-history me-2"></i> Auditoría
                    </NavLink>
                </div>
            </div>
        }
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;
    private bool showRegistros = false;
    private bool showConfig = false;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;
    private void ToggleNavMenu() => collapseNavMenu = !collapseNavMenu;
    private void CollapseNavMenu() => collapseNavMenu = true;
    private void ToggleRegistros() => showRegistros = !showRegistros;
    private void ToggleConfig() => showConfig = !showConfig;
}
