@rendermode InteractiveServer
@using Turnos.Models
@inject WhatsAppService WhatsApp
@inject EventService EventSvc

<div class="modal fade @(Show ? "show d-block" : "")" tabindex="-1" style="background: rgba(0,0,0,0.4)">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-whatsapp text-success me-2"></i>Enviar Mensaje de WhatsApp</h5>
                <button class="btn-close" @onclick="Close"></button>
            </div>
            <div class="modal-body">
                @if (sent)
                {
                    <div class="alert alert-success">Mensaje enviado!</div>
                }
                else if (!string.IsNullOrEmpty(error))
                {
                    <div class="alert alert-danger">@error</div>
                }
                else
                {
                    <div class="mb-3">
                        <label class="form-label">Plantilla</label>
                        <select class="form-select" @bind="selectedTemplate" @bind:after="OnTemplateChanged">
                            <option value="">— Mensaje manual —</option>
                            <option value="OpenAssignment">Asignación abierta (solicitar disponibilidad)</option>
                            <option value="AssignmentNotification">Notificación de asignación</option>
                            <option value="EventReminder">Recordatorio de evento</option>
                            <option value="SupervisorDetails">Detalles para el supervisor</option>
                            <option value="EventDetails">Información completa del evento (fecha, horario, ubicación, parking, GPS)</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Mensaje</label>
                        <textarea class="form-control" rows="4" @bind="messageBody"></textarea>
                    </div>

                    @if (PersonId is null && EventId.HasValue && currentEvent is not null)
                    {
                        var activeAssignments = currentEvent.Assignments
                            .Where(a => a.Status != AssignmentStatus.Candidato)
                            .ToList();
                        @if (activeAssignments.Count > 0)
                        {
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Enviar a personas:</label>
                                <div class="border rounded p-2" style="max-height:160px;overflow-y:auto">
                                    @foreach (var a in activeAssignments)
                                    {
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="person_@a.PersonId"
                                                   checked="@selectedPersonIds.Contains(a.PersonId)"
                                                   @onchange="e => TogglePerson(a.PersonId, (bool)(e.Value ?? false))" />
                                            <label class="form-check-label" for="person_@a.PersonId">
                                                @a.Person.FullName
                                                <span class="badge @GetStatusBadge(a.Status) ms-1" style="font-size:.7em">@a.Status</span>
                                            </label>
                                        </div>
                                    }
                                </div>
                                <div class="mt-1 small">
                                    <button class="btn btn-link btn-sm p-0" @onclick="() => SelectAll(activeAssignments)">Todos</button>
                                    <span class="text-muted mx-1">·</span>
                                    <button class="btn btn-link btn-sm p-0" @onclick="SelectNone">Ninguno</button>
                                    <span class="text-muted ms-2">(@selectedPersonIds.Count seleccionados)</span>
                                </div>
                            </div>
                        }
                    }

                    @if (allGroups.Count > 0)
                    {
                        <div class="mb-1">
                            <label class="form-label fw-semibold">Enviar a grupos:</label>
                            <div class="border rounded p-2" style="max-height:160px;overflow-y:auto">
                                @foreach (var g in allGroups)
                                {
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="group_@g.GroupId"
                                               checked="@selectedGroupIds.Contains(g.GroupId)"
                                               @onchange="e => ToggleGroup(g.GroupId, (bool)(e.Value ?? false))" />
                                        <label class="form-check-label" for="group_@g.GroupId">
                                            @g.Name
                                            @if (!string.IsNullOrEmpty(g.Notes))
                                            {
                                                <span class="text-muted small ms-1">— @g.Notes</span>
                                            }
                                        </label>
                                    </div>
                                }
                            </div>
                            <div class="mt-1 small">
                                <button class="btn btn-link btn-sm p-0" @onclick="SelectAllGroups">Todos</button>
                                <span class="text-muted mx-1">·</span>
                                <button class="btn btn-link btn-sm p-0" @onclick="SelectNoGroups">Ninguno</button>
                                <span class="text-muted ms-2">(@selectedGroupIds.Count seleccionados)</span>
                            </div>
                        </div>
                    }
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="Close">Cancelar</button>
                @if (!sent)
                {
                    <button class="btn btn-success" @onclick="Send" disabled="@sending">
                        <i class="bi bi-send me-1"></i> @(sending ? "Enviando…" : "Enviar")
                    </button>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public bool Show { get; set; }
    [Parameter] public int? PersonId { get; set; }
    [Parameter] public int? EventId { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private string selectedTemplate = "";
    private string messageBody = "";
    private HashSet<int> selectedPersonIds = new();
    private HashSet<int> selectedGroupIds = new();
    private List<WhatsAppGroup> allGroups = new();
    private bool sending;
    private bool sent;
    private string? error;
    private Event? currentEvent;

    protected override async Task OnParametersSetAsync()
    {
        allGroups = await WhatsApp.GetGroupsAsync();

        if (EventId.HasValue)
        {
            currentEvent = await EventSvc.GetByIdAsync(EventId.Value);
            selectedPersonIds = currentEvent?.Assignments
                .Where(a => a.Status != AssignmentStatus.Candidato)
                .Select(a => a.PersonId)
                .ToHashSet() ?? new();
        }
    }

    private void OnTemplateChanged()
    {
        if (string.IsNullOrEmpty(selectedTemplate) || currentEvent is null) return;
        var person = new Person { FullName = "Personnel" };
        messageBody = WhatsApp.BuildTemplateMessage(selectedTemplate, currentEvent, person);
    }

    private async Task Send()
    {
        if (string.IsNullOrWhiteSpace(messageBody)) { error = "El mensaje no puede estar vacío."; return; }
        sending = true;
        error = null;
        try
        {
            if (PersonId is null && EventId.HasValue)
            {
                foreach (var personId in selectedPersonIds)
                    await WhatsApp.SendMessageAsync(personId, selectedTemplate ?? "Custom", messageBody, EventId);
            }
            else if (PersonId.HasValue)
                await WhatsApp.SendMessageAsync(PersonId.Value, selectedTemplate ?? "Custom", messageBody, EventId);

            foreach (var groupId in selectedGroupIds)
                await WhatsApp.SendToGroupAsync(groupId, selectedTemplate ?? "Custom", messageBody, EventId);

            sent = true;
        }
        catch (Exception ex)
        {
            error = $"Error: {ex.Message}";
        }
        sending = false;
    }

    private void TogglePerson(int personId, bool selected)
    {
        if (selected) selectedPersonIds.Add(personId);
        else selectedPersonIds.Remove(personId);
    }

    private void SelectAll(List<Assignment> assignments)
        => selectedPersonIds = assignments.Select(a => a.PersonId).ToHashSet();

    private void SelectNone() => selectedPersonIds.Clear();

    private void ToggleGroup(int groupId, bool selected)
    {
        if (selected) selectedGroupIds.Add(groupId);
        else selectedGroupIds.Remove(groupId);
    }

    private void SelectAllGroups() => selectedGroupIds = allGroups.Select(g => g.GroupId).ToHashSet();
    private void SelectNoGroups() => selectedGroupIds.Clear();

    private static string GetStatusBadge(AssignmentStatus status) => status switch
    {
        AssignmentStatus.Confirmado => "bg-success",
        AssignmentStatus.Asignado => "bg-primary",
        AssignmentStatus.Disponible => "bg-info text-dark",
        AssignmentStatus.Ofrecido => "bg-warning text-dark",
        AssignmentStatus.Candidato => "bg-secondary",
        _ => "bg-secondary"
    };

    private async Task Close()
    {
        sent = false;
        error = null;
        messageBody = "";
        selectedTemplate = "";
        selectedPersonIds.Clear();
        selectedGroupIds.Clear();
        await OnClose.InvokeAsync();
    }
}
